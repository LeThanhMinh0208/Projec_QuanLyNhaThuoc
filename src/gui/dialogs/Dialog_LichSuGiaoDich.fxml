<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="750.0" prefWidth="1050.0" spacing="20.0" styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialogs.Dialog_LichSuGiaoDichController">

    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css"/>
        <URL value="@../../resources/css/BanHang.css"/>
    </stylesheets>

    <padding><Insets bottom="25.0" left="30.0" right="30.0" top="25.0"/></padding>

    <VBox spacing="5">
        <Label text="Lịch Sử Giao Dịch" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0284c7;"/>
        <Label fx:id="lblTieuDeKH" text="Xem toàn bộ lịch sử mua hàng của khách hàng: ---" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
    </VBox>

    <HBox spacing="15">
        <VBox styleClass="panel-white" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 15 20; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Tổng hóa đơn" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            <Label fx:id="lblTongHD" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        </VBox>
        <VBox styleClass="panel-white" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 15 20; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Tổng chi tiêu" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            <Label fx:id="lblTongTien" text="0 ₫" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
        </VBox>
        <VBox styleClass="panel-white" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 15 20; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Điểm tích lũy" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            <Label fx:id="lblDiem" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0ea5e9;"/>
        </VBox>
        <VBox styleClass="panel-white" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 15 20; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Lần mua gần nhất" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            <Label fx:id="lblLanMuaCuoi" text="---" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
        </VBox>
    </HBox>

    <VBox styleClass="panel-white" style="-fx-padding: 15 20; -fx-border-radius: 8; -fx-background-radius: 8;">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" styleClass="search-box" prefWidth="250" HBox.hgrow="ALWAYS">
                <Label styleClass="search-icon" text="🔍"/>
                <TextField fx:id="txtTimKiem" promptText="Tìm theo mã hóa đơn..." styleClass="search-input" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label text="Hình thức:" style="-fx-text-fill:#64748b;"/>
            <ComboBox fx:id="cbHinhThuc" prefWidth="130"/>
            <Label text="Từ ngày:" style="-fx-text-fill:#64748b;"/>
            <DatePicker fx:id="dpTuNgay" prefWidth="130"/>
            <Label text="Đến ngày:" style="-fx-text-fill:#64748b;"/>
            <DatePicker fx:id="dpDenNgay" prefWidth="130"/>
            <Button text="✕ Bỏ lọc" onAction="#handleXoaLoc" styleClass="bh-btn-secondary" prefHeight="38"/>
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white" style="-fx-padding:0; -fx-border-radius: 8; -fx-background-radius: 8;">
        <HBox style="-fx-padding: 12 20; -fx-background-color: #f8fafc; -fx-background-radius: 8 8 0 0; -fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 1;">
             <Label text="Danh sách hóa đơn" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1e293b;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
             <Label fx:id="lblSoGiaoDich" text="0 giao dịch" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
        </HBox>
        <TableView fx:id="tableGiaoDich" VBox.vgrow="ALWAYS" style="-fx-background-radius: 0 0 8 8;">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            <placeholder>
                <Label text="Chưa có giao dịch nào phù hợp" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colMaHD"     text="Mã HĐ"        prefWidth="100"/>
                <TableColumn fx:id="colNgayLap"  text="Ngày Lập"     prefWidth="120"/>
                <TableColumn fx:id="colNhanVien" text="Nhân Viên"    prefWidth="150"/>
                <TableColumn fx:id="colTamTinh"  text="Tạm Tính"     prefWidth="120"/>
                <TableColumn fx:id="colVAT"      text="VAT"          prefWidth="60"/>
                <TableColumn fx:id="colTongTT"   text="Tổng TT"      prefWidth="120"/>
                <TableColumn fx:id="colHinhThuc" text="Hình Thức"    prefWidth="130"/>
                <TableColumn fx:id="colHanhDong" text=""             prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
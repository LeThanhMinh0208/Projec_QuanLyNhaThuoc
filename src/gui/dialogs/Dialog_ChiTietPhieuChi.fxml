<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="580.0" spacing="0.0" styleClass="dialog-container" stylesheets="@../../resources/css/QuanLyCongNo.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_ChiTietPhieuChiController">
   <children>
      <VBox spacing="5" styleClass="dialog-header-area">
         <children>
            <Label styleClass="dialog-title" text="✨ CHI TIẾT PHIẾU CHI TIỀN" />
            <HBox spacing="10">
               <children>
                  <Label style="-fx-text-fill: #bfdbfe;" text="Mã phiếu:" />
                  <Label fx:id="lblMaPhieu" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" text="---" />
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox spacing="25.0" style="-fx-padding: 30;">
         <children>
            <VBox spacing="15" style="-fx-background-color: #f1f5f9; -fx-padding: 20; -fx-background-radius: 10;">
               <children>
                  <GridPane hgap="15.0" vgap="15.0">
                     <columnConstraints>
                        <ColumnConstraints minWidth="130.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                     </columnConstraints>
                     <children>
                        <Label styleClass="dialog-label-static" text="Nhà cung cấp:" GridPane.rowIndex="0" />
                        <Label fx:id="lblNhaCungCap" styleClass="dialog-value-text" style="-fx-text-fill: #0284c7;" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label styleClass="dialog-label-static" text="Ngày chi:" GridPane.rowIndex="1" />
                        <Label fx:id="lblNgayChi" styleClass="dialog-value-text" text="---" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="dialog-label-static" text="Người lập:" GridPane.rowIndex="2" />
                        <Label fx:id="lblNhanVien" styleClass="dialog-value-text" text="---" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label styleClass="dialog-label-static" text="Hình thức:" GridPane.rowIndex="3" />
                        <Label fx:id="lblHinhThuc" styleClass="dialog-value-text" text="---" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                     </children>
                  </GridPane>
               </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ecfdf5; -fx-padding: 15; -fx-border-color: #10b981; -fx-border-width: 0 0 0 5; -fx-background-radius: 0 8 8 0;">
               <children>
                  <Label styleClass="dialog-label-static" text="TỔNG TIỀN ĐÃ CHI:" />
                  <Label fx:id="lblTongTien" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #059669;" text="0 VNĐ" />
               </children>
            </HBox>

            <VBox spacing="8">
               <children>
                  <Label styleClass="dialog-label-static" text="Ghi chú / Nội dung:" />
                  <TextArea fx:id="txtGhiChu" editable="false" prefRowCount="3" styleClass="dialog-input-field" style="-fx-control-inner-background: #ffffff;" />
               </children>
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button fx:id="btnDong" onAction="#handleDong" prefHeight="45.0" prefWidth="120.0" styleClass="btn-dialog-cancel" text="Đóng" />
                  <Button onAction="#handleInPhieu" prefHeight="45.0" prefWidth="160.0" styleClass="btn-dialog-print" text="🖨 IN PHIẾU" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="900.0" spacing="0.0" styleClass="ds-dialog-root" 
      stylesheets="@../../resources/css/DanhMucThuoc.css" 
      xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.dialogs.Dialog_ThemNhaCungCapController">

    <children>
        <HBox alignment="CENTER_LEFT" styleClass="ds-header-area">
            <children>
                <Label styleClass="ds-dialog-title" text="✨ THÊM NHÀ CUNG CẤP MỚI VÀO HỆ THỐNG " />
            </children>
        </HBox>

        <VBox spacing="25.0">
            <padding>
                <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
            </padding>
            <children>
                <HBox spacing="40.0">
                    <children>
                        <VBox alignment="TOP_CENTER" spacing="15.0" />

                        <GridPane hgap="15.0" vgap="20.0" HBox.hgrow="ALWAYS">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints minWidth="120.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="Mã Nhà Cung Cấp" GridPane.rowIndex="0" />
                                <TextField fx:id="txtMa" disable="true" opacity="0.5" prefHeight="40.0" promptText="Mã tự động" 
                                           styleClass="ds-input, ds-input-readonly" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Tên Nhà Cung Cấp:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                <TextField fx:id="txtTen" prefHeight="40.0" promptText="Nhập tên nhà cung cấp" 
                                           styleClass="ds-input" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                <Label text="Số Điện Thoại:" GridPane.rowIndex="1" />
                                <TextField fx:id="txtSdt" prefHeight="40.0" promptText="Nhập số điện thoại" 
                                           styleClass="ds-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Địa Chỉ:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                <TextField fx:id="txtDiaChi" prefHeight="40.0" promptText="Nhập địa chỉ đầy đủ" 
                                           styleClass="ds-input" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                <Label text="Công Nợ (VNĐ):" GridPane.rowIndex="2" />
                                <TextField fx:id="txtCongNo" disable="true" opacity="0.5" prefHeight="40.0" promptText="0 nếu không có công nợ" 
                                           styleClass="ds-input, ds-input-readonly" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            </children>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>
                        </GridPane>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="20.0">
                    <children>
                        <Button onAction="#handleHuy" prefHeight="50.0" prefWidth="160.0" 
                                styleClass="ds-btn-cancel" text="Hủy Thao Tác" />
                        <Button onAction="#handleLuu" prefHeight="50.0" prefWidth="240.0" 
                                styleClass="ds-btn-save" text="LƯU NHÀ CUNG CẤP MỚI ✨" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
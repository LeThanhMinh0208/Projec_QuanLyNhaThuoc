<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: white; -fx-background-radius: 10;" stylesheets="@../../resources/css/XuatKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_TaoPhieuXuatController">
   
   <HBox alignment="CENTER_LEFT" styleClass="dialog-header-bg">
      <Label fx:id="lblTieuDe" styleClass="dialog-title-text" text="LẬP PHIẾU CHUYỂN KHO" />
      <Region HBox.hgrow="ALWAYS" />
      <Label fx:id="lblLoaiPhieu" styleClass="badge-chuyen" text="CHUYỂN KHO" />
   </HBox>

   <VBox spacing="15.0" style="-fx-padding: 20;">
      <HBox spacing="20.0" alignment="CENTER_LEFT">
         <Label styleClass="form-label" text="Mã Phiếu:" prefWidth="80.0"/>
         <TextField fx:id="txtMaPhieu" disable="true" style="-fx-font-weight: bold; -fx-opacity: 1;" prefWidth="150.0" />
         
         <Label fx:id="lblKhoXuat" styleClass="form-label" text="Từ Kho:" />
         <ComboBox fx:id="cmbKhoXuat" prefWidth="150.0" />

         <Label fx:id="lblDacThu" styleClass="form-label" text="Đến Kho:" />
         <StackPane>
            <ComboBox fx:id="cmbKhoNhan" prefWidth="180.0" visible="true" />
            <ComboBox fx:id="cmbNhaCungCap" prefWidth="180.0" visible="false" />
         </StackPane>
      </HBox>
      <HBox spacing="20.0" alignment="CENTER_LEFT">
         <Label styleClass="form-label" text="Lý do/Ghi chú:" prefWidth="100.0" />
         <TextField fx:id="txtGhiChu" promptText="Nhập lý do chuyển/hủy..." HBox.hgrow="ALWAYS" />
      </HBox>
   </VBox>

   <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 20;">
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="Danh sách thuốc cần xuất (Auto FEFO)" />
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#handleThemDong" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;" text="➕ Chọn Thuốc" />
      </HBox>
      <TableView fx:id="tableChiTiet" styleClass="table-fefo" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colTenThuoc" prefWidth="300.0" text="Tên Thuốc" />
            <TableColumn fx:id="colSLYeuCau" prefWidth="120.0" text="SL Yêu Cầu" />
            <TableColumn fx:id="colTrangThaiFEFO" prefWidth="450.0" text="Trạng thái phân bổ Lô (FEFO)" />
            <TableColumn fx:id="colXoa" prefWidth="80.0" text="Xóa" style="-fx-alignment: CENTER;"/>
         </columns>
      </TableView>
   </VBox>

   <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 20;">
      <Button onAction="#handleLuuPhieu" prefHeight="45.0" prefWidth="180.0" styleClass="btn-save" text="💾 XÁC NHẬN LƯU" />
      <Button onAction="#handleDong" prefHeight="45.0" prefWidth="100.0" styleClass="btn-cancel" text="Đóng" />
   </HBox>
</VBox>
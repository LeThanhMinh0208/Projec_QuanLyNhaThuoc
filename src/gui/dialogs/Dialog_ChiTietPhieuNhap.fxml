<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="20.0" styleClass="nk-main-bg" stylesheets="@../../resources/css/NhapKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_ChiTietPhieuNhapController">
   <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>
   <children>
      <VBox spacing="5.0">
         <children>
            <Label style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #0369a1;" text="CHI TIẾT PHIẾU NHẬP KHO" />
            <Label fx:id="lblMaPhieu" style="-fx-font-size: 16px; -fx-text-fill: #475569; -fx-font-weight: bold;" text="Mã phiếu: PN---" />
         </children>
      </VBox>

      <VBox styleClass="nk-card" style="-fx-padding: 20;">
         <children>
            <GridPane hgap="40.0" vgap="15.0">
               <columnConstraints>
                  <ColumnConstraints prefWidth="120.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
                  <ColumnConstraints prefWidth="120.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>
               <children>
                  <Label text="Nhà cung cấp:" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <Label fx:id="lblNhaCungCap" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  
                  <Label text="Ngày nhập kho:" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <Label fx:id="lblNgayNhap" text="---" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label text="Người lập phiếu:" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <Label fx:id="lblNguoiLap" text="---" GridPane.columnIndex="3" GridPane.rowIndex="0" />
               </children>
            </GridPane>
         </children>
      </VBox>

      <VBox styleClass="nk-card" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="tableChiTiet" styleClass="nk-table" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colTenThuoc" prefWidth="200.0" text="TÊN THUỐC" />
                  <TableColumn fx:id="colDonVi" prefWidth="80.0" text="ĐƠN VỊ" />
                  <TableColumn fx:id="colSoLuong" prefWidth="90.0" text="SL NHẬN" />
                  <TableColumn fx:id="colMaLo" prefWidth="110.0" text="MÃ LÔ" />
                  <TableColumn fx:id="colNgaySX" prefWidth="100.0" text="NGÀY SX" />
                  <TableColumn fx:id="colHanDung" prefWidth="100.0" text="HẠN DÙNG" />
                  <TableColumn fx:id="colGiaNhap" prefWidth="120.0" text="GIÁ NHẬP" />
                  <TableColumn fx:id="colThanhTien" prefWidth="130.0" text="THÀNH TIỀN" />
               </columns>
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
         </children>
      </VBox>

<HBox alignment="CENTER_RIGHT" spacing="20.0">
         <children>
            <Label text="Tổng tiền thanh toán:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
            <Label fx:id="lblTongTien" text="0 VNĐ" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #e11d48;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleDong" prefHeight="40.0" prefWidth="100.0" styleClass="btn-cancel" text="Đóng" />
            <Button mnemonicParsing="false" onAction="#handleInPhieu" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: linear-gradient(to right, #3b82f6, #2563eb); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;" text="🖨 In Phiếu" />
         </children>
      </HBox>
   </children>
</VBox>
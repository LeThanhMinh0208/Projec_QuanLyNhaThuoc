<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="950.0" prefHeight="850.0" spacing="0.0" styleClass="dialog-root" stylesheets="@../../resources/css/XuatKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_XuatHuyController">
   <children>
      <AnchorPane prefHeight="70.0" styleClass="dialog-header-gradient">
         <children>
            <Label layoutX="25.0" layoutY="20.0" styleClass="dialog-header-title" text="🗑 LẬP PHIẾU XUẤT HỦY THUỐC" AnchorPane.leftAnchor="25.0" />
            <Button onAction="#handleImportCSV" styleClass="btn-import-header" text="📥 Nhập từ file CSV" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="18.0" />
         </children>
      </AnchorPane>

      <VBox spacing="15.0" style="-fx-padding: 15 25 20 25;">
         <children>
          <GridPane hgap="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
   <columnConstraints>
      <ColumnConstraints percentWidth="50.0" />
      <ColumnConstraints percentWidth="50.0" />
   </columnConstraints>
   <children>
      <VBox spacing="5.0" GridPane.columnIndex="0">
         <Label styleClass="input-label-title" text="Người Lập Phiếu Xuất Hủy:" />
         <TextField fx:id="txtNguoiLap" disable="true" editable="false" prefHeight="38.0" styleClass="input-field, input-field-readonly" />
      </VBox>
      <VBox spacing="5.0" GridPane.columnIndex="1">
         <Label styleClass="input-label-title" text="Nơi Hủy:" />
         <TextField fx:id="txtNoiHuy" editable="false" prefHeight="38.0" styleClass="input-field, input-field-readonly" text="Hủy Rác Y Tế" />
      </VBox>
   </children>
</GridPane>

            <VBox spacing="10.0" styleClass="xk-card" style="-fx-padding: 15; -fx-border-color: #0ea5e9; -fx-border-width: 1.2; -fx-border-radius: 10;">
               <children>
                   <HBox spacing="15.0" alignment="BOTTOM_LEFT">
                      <VBox spacing="5.0" prefWidth="250.0">
                          <Label styleClass="input-label-title" text="🔍 Tìm thuốc nhanh:" />
                          <TextField fx:id="txtTimNhanhThuoc" prefHeight="38.0" promptText="Nhập tên hoặc mã..." styleClass="input-field" />
                      </VBox>
                      <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                          <Label styleClass="input-label-title" text="💊 Danh sách Thuốc có hàng trong hệ thống:" />
                          <ComboBox fx:id="cbChonThuoc" prefHeight="38.0" maxWidth="Infinity" promptText="-- Chọn thuốc --" styleClass="input-field" />
                      </VBox>
                   </HBox>

                   <HBox spacing="15.0" alignment="BOTTOM_LEFT">
                      <VBox spacing="5.0" prefWidth="420.0">
                          <Label styleClass="input-label-title" text="📦 Chọn Lô thuốc (Hiển thị tất cả các kho):" />
                          <ComboBox fx:id="cbChonLo" prefHeight="38.0" maxWidth="Infinity" promptText="-- Chọn Lô --" styleClass="input-field" />
                      </VBox>
                      <VBox spacing="5.0" prefWidth="120.0">
                          <Label styleClass="input-label-title" text="SL Hủy:" />
                          <TextField fx:id="txtSoLuongHuy" prefHeight="38.0" alignment="CENTER" styleClass="input-field" />
                      </VBox>
                      <Region HBox.hgrow="ALWAYS" />
                      <Button onAction="#handleThemThuoc" minWidth="160.0" prefHeight="40.0" styleClass="btn-success" text="+ THÊM VÀO BẢNG" />
                   </HBox>
               </children>
            </VBox>

            <TableView fx:id="tableThuocHuy" minHeight="250.0" prefHeight="300.0" styleClass="xk-table" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colSTT" maxWidth="50.0" minWidth="50.0" text="STT" />
                  <TableColumn fx:id="colTenThuoc" minWidth="380.0" text="TÊN THUỐC" />
                  <TableColumn fx:id="colSoLo" minWidth="150.0" text="SỐ LÔ" />
                  <TableColumn fx:id="colSoLuong" maxWidth="120.0" text="SL HỦY" />
                  <TableColumn fx:id="colXoa" maxWidth="60.0" text="XÓA" />
               </columns>
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>

            <VBox spacing="5.0">
                <Label styleClass="input-label-title" text="Lý do xuất hủy (*):" />
                <TextField fx:id="txtGhiChu" prefHeight="38.0" promptText="Bắt buộc nhập lý do (VD: Thuốc hết hạn, vỡ hỏng...)" styleClass="input-field" />
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <Button onAction="#handleHuyBo" prefHeight="45.0" prefWidth="120.0" styleClass="btn-cancel" text="Hủy Bỏ" />
               <Button onAction="#handleXacNhanHuy" prefHeight="45.0" prefWidth="250.0" styleClass="btn-success" text="✔ XÁC NHẬN XUẤT HỦY" />
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
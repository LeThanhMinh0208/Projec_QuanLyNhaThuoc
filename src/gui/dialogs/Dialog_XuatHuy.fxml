<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="950.0" prefHeight="850.0" spacing="15.0" styleClass="dialog-container" stylesheets="@../../resources/css/XuatKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_XuatHuyController">
   <children>
      <Label styleClass="dialog-title" text="🗑 LẬP LỆNH XUẤT HỦY THUỐC" />
      
      <GridPane hgap="20.0" vgap="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
         <columnConstraints>
            <ColumnConstraints percentWidth="50.0" />
            <ColumnConstraints percentWidth="50.0" />
         </columnConstraints>
         <children>
            <VBox spacing="5.0" GridPane.columnIndex="0">
               <Label styleClass="input-label-title" text="Người Lập Phiếu:" />
               <TextField fx:id="txtNguoiLap" disable="true" editable="false" prefHeight="40.0" styleClass="input-field, input-field-readonly" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1">
               <Label styleClass="input-label-title" text="Kho Xuất Hủy (*):" />
               <ComboBox fx:id="cbKhoXuat" prefHeight="40.0" maxWidth="Infinity" promptText="-- Chọn kho xuất --" styleClass="input-field" />
            </VBox>
         </children>
      </GridPane>

      <VBox spacing="10.0" styleClass="xk-card" style="-fx-padding: 15; -fx-border-color: #0ea5e9; -fx-border-width: 1; -fx-border-radius: 8;">
         <children>
             <HBox spacing="15.0" alignment="BOTTOM_LEFT">
                <VBox spacing="5.0" prefWidth="250.0">
                    <Label styleClass="input-label-title" text="🔍 Tìm thuốc nhanh:" />
                    <TextField fx:id="txtTimNhanhThuoc" prefHeight="40.0" promptText="Nhập tên hoặc mã..." styleClass="input-field" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="input-label-title" text="💊 Danh sách Thuốc:" />
                    <ComboBox fx:id="cbChonThuoc" prefHeight="40.0" maxWidth="Infinity" promptText="-- Chọn thuốc --" styleClass="input-field" />
                </VBox>
             </HBox>

             <HBox spacing="15.0" alignment="BOTTOM_LEFT">
                <VBox spacing="5.0" prefWidth="400.0">
                    <Label styleClass="input-label-title" text="📦 Lô thuốc cần hủy:" />
                    <ComboBox fx:id="cbChonLo" prefHeight="40.0" prefWidth="400.0" promptText="-- Chọn Lô --" styleClass="input-field" />
                </VBox>
                <VBox spacing="5.0" prefWidth="150.0">
                    <Label styleClass="input-label-title" text="SL Hủy:" />
                    <TextField fx:id="txtSoLuongHuy" prefHeight="40.0" promptText="Số lượng" styleClass="input-field" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleThemThuoc" minWidth="180.0" prefHeight="45.0" styleClass="btn-success" text="+ THÊM VÀO BẢNG" />
             </HBox>
         </children>
      </VBox>

      <TableView fx:id="tableThuocHuy" styleClass="xk-table" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colSTT" prefWidth="60.0" text="STT" />
            <TableColumn fx:id="colTenThuoc" prefWidth="400.0" text="TÊN THUỐC" />
            <TableColumn fx:id="colSoLo" prefWidth="180.0" text="SỐ LÔ" />
            <TableColumn fx:id="colSoLuong" prefWidth="150.0" text="SL HỦY" />
            <TableColumn fx:id="colXoa" prefWidth="100.0" text="XÓA" />
         </columns>
         <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
      </TableView>

      <VBox spacing="5.0">
          <Label styleClass="input-label-title" text="Lý do hủy hàng (*):" />
          <TextField fx:id="txtGhiChu" prefHeight="40.0" promptText="Bắt buộc nhập lý do (VD: Hết hạn sử dụng, Rách bao bì, Thu hồi...)" styleClass="input-field" />
      </VBox>

      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <Button onAction="#handleHuyBo" prefHeight="45.0" prefWidth="120.0" styleClass="btn-cancel" text="Hủy Bỏ" />
         <Button onAction="#handleXacNhanHuy" prefHeight="45.0" prefWidth="250.0" styleClass="btn-success" text="✔ XÁC NHẬN XUẤT HỦY" />
      </HBox>
   </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="550.0" spacing="0.0" styleClass="ds-dialog-root" 
      stylesheets="@../../resources/css/DanhMuc.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.dialogs.Dialog_XoaThuocController">

    <children>
        <HBox styleClass="ds-header-danger-area" alignment="CENTER_LEFT">
            <children>
                <Label text="⚠ XÁC NHẬN XÓA THUỐC" styleClass="ds-dialog-title" />
            </children>
        </HBox>

        <VBox spacing="25.0" alignment="CENTER">
            <padding>
                <Insets top="35" right="30" bottom="30" left="30" />
            </padding>
            <children>
                <Label text="❓" style="-fx-font-size: 60px;" />
                
                <Label text="Bạn có chắc chắn muốn xóa thuốc này?" 
                       style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                
                <VBox alignment="CENTER" spacing="8" 
                      style="-fx-background-color: #fef2f2; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #fee2e2; -fx-border-radius: 12; -fx-border-width: 2;">
                    <children>
                        <Label text="Tên loại thuốc đã chọn:" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
                        <Label fx:id="lblTenThuoc" text="[Tên thuốc]" 
                               style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-font-size: 20px;" 
                               wrapText="true" textAlignment="CENTER" />
                    </children>
                </VBox>

                <Label text="Hành động này không thể hoàn tác trong tương lai!" 
                       style="-fx-text-fill: #64748b; -fx-font-style: italic; -fx-font-size: 13px;" />

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="btnHuy" onAction="#handleHuy" prefHeight="48.0" prefWidth="150.0" 
                                text="Quay Lại" styleClass="ds-btn-cancel" style="-fx-font-weight: bold;" />
                        <Button onAction="#handleXoa" prefHeight="48.0" prefWidth="180.0" 
                                text="VẪN XÓA 🔥" styleClass="ds-btn-danger" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
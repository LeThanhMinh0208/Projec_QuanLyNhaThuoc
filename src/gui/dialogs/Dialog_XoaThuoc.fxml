<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="550.0" spacing="0.0" styleClass="ds-dialog-root" 
      stylesheets="@../../resources/css/DanhMucThuoc.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.dialogs.Dialog_XoaThuocController">

    <children>
        <HBox styleClass="ds-header-danger-area" alignment="CENTER_LEFT">
            <children>
                <Label text="⚠ Xác nhận xóa" styleClass="ds-dialog-title" />
            </children>
        </HBox>

        <VBox spacing="25.0" alignment="CENTER">
            <padding>
                <Insets top="35" right="30" bottom="30" left="30" />
            </padding>
            <children>
                <Label text="❓" style="-fx-font-size: 60px;" />
                
                <Label text="Bạn có chắc muốn xóa thuốc này không?" 
                       style="-fx-font-size: 15px; -fx-text-fill: #1e293b;" 
                       wrapText="true" textAlignment="CENTER" />
                
                <VBox alignment="CENTER" spacing="8" 
                      style="-fx-background-color: #fef2f2; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #fee2e2; -fx-border-radius: 12; -fx-border-width: 2;">
                    <children>
                        <Label text="Tên loại thuốc đã chọn:" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
                        <Label fx:id="lblTenThuoc" text="[Tên thuốc]" 
                               style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-font-size: 20px;" 
                               wrapText="true" textAlignment="CENTER" />
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="btnHuy" onAction="#handleHuy" prefHeight="48.0" prefWidth="150.0" 
                                text="Hủy" styleClass="ds-btn-cancel" style="-fx-font-weight: bold;" />
                        <Button fx:id="btnXoa" onAction="#handleXoa" prefHeight="48.0" prefWidth="180.0" 
                                text="Xóa" styleClass="ds-btn-danger" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefWidth="400.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_XoaThuocController">
   <children>
      <Label style="-fx-font-size: 40px; -fx-text-fill: #ef4444;" text="⚠️" />
      <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Bạn có chắc chắn muốn xóa thuốc này?" />
      <Label fx:id="lblTenThuoc" style="-fx-font-size: 16px; -fx-text-fill: #0ea5e9; -fx-font-style: italic;" text="Tên Thuốc" />
      
      <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10 0 0 0;">
         <Button fx:id="btnHuy" onAction="#handleHuy" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8 20;" text="Hủy" />
         <Button onAction="#handleXoa" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" text="Xác Nhận Xóa" />
      </HBox>
   </children>
</VBox>
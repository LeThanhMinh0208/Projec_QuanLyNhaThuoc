<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="950.0" prefHeight="850.0" spacing="0.0" styleClass="dialog-root" stylesheets="@../../resources/css/XuatKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_XuatChuyenKhoController">
   <children>
      <AnchorPane prefHeight="65.0" styleClass="dialog-header-gradient">
         <children>
            <Label layoutX="25.0" layoutY="18.0" styleClass="dialog-header-title" text="🚚 LẬP PHIẾU CHUYỂN KHO NỘI BỘ" AnchorPane.leftAnchor="25.0" />
            <Button onAction="#handleImportCSV" styleClass="btn-import-header" text="📥 Nhập từ file CSV" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="15.0" />
         </children>
      </AnchorPane>

      <VBox spacing="15.0" style="-fx-padding: 15 25 20 25;">
         <children>
            <GridPane hgap="15.0" vgap="8.0" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
               <columnConstraints>
                  <ColumnConstraints percentWidth="25.0" />
                  <ColumnConstraints percentWidth="25.0" />
                  <ColumnConstraints percentWidth="25.0" />
                  <ColumnConstraints percentWidth="25.0" />
               </columnConstraints>
               <children>
                  <VBox spacing="3.0" GridPane.columnIndex="0">
                     <Label styleClass="input-label-title" text="Người Lập Phiếu:" />
                     <TextField disable="true" fx:id="txtNguoiLap" editable="false" prefHeight="35.0" styleClass="input-field, input-field-readonly" />
                  </VBox>
                  <VBox spacing="3.0" GridPane.columnIndex="1">
                     <Label styleClass="input-label-title" text="Người Vận Chuyển:" />
                     <TextField fx:id="txtNguoiVanChuyen" prefHeight="35.0" promptText="Nhập tên..." styleClass="input-field" />
                  </VBox>
                  <VBox spacing="3.0" GridPane.columnIndex="2">
                     <Label styleClass="input-label-title" text="Kho Xuất (*):" />
                     <ComboBox fx:id="cbKhoXuat" prefHeight="35.0" prefWidth="250.0" styleClass="input-field" />
                  </VBox>
                  <VBox spacing="3.0" GridPane.columnIndex="3">
                     <Label styleClass="input-label-title" text="Kho Nhận (*):" />
                     <TextField fx:id="txtKhoNhan" editable="false" prefHeight="35.0" styleClass="input-field, input-field-readonly" />
                  </VBox>
               </children>
            </GridPane>

            <VBox spacing="10.0" styleClass="xk-card" style="-fx-padding: 15; -fx-border-color: #0ea5e9; -fx-border-width: 1.2; -fx-border-radius: 10;">
               <children>
                   <HBox spacing="15.0" alignment="BOTTOM_LEFT">
                      <VBox spacing="3.0" prefWidth="250.0">
                          <Label styleClass="input-label-title" text="🔍 Tìm thuốc nhanh:" />
                          <TextField fx:id="txtTimNhanhThuoc" prefHeight="35.0" promptText="Nhập tên..." styleClass="input-field" />
                      </VBox>
                      <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                          <Label styleClass="input-label-title" text="💊 Danh sách Thuốc:" />
                          <ComboBox fx:id="cbChonThuoc" prefHeight="35.0" prefWidth="600.0" promptText="-- Chọn thuốc --" styleClass="input-field" />
                      </VBox>
                   </HBox>

                   <HBox spacing="15.0" alignment="BOTTOM_LEFT">
                      <VBox spacing="3.0" prefWidth="400.0">
                          <Label styleClass="input-label-title" text="📦 Lô đang tồn tại kho xuất:" />
                          <ComboBox fx:id="cbChonLo" prefHeight="35.0" prefWidth="400.0" styleClass="input-field" />
                      </VBox>
                      <VBox spacing="3.0" prefWidth="120.0">
                          <Label styleClass="input-label-title" text="SL Chuyển:" />
                          <TextField fx:id="txtSoLuongChuyen" alignment="CENTER" prefHeight="35.0" styleClass="input-field" />
                      </VBox>
                      <Region HBox.hgrow="ALWAYS" />
                      <Button onAction="#handleThemThuoc" minWidth="160.0" prefHeight="38.0" styleClass="btn-success" text="+ THÊM VÀO BẢNG" />
                   </HBox>
               </children>
            </VBox>
<TableView fx:id="tableThuocChuyen" 
           VBox.vgrow="ALWAYS" 
           minHeight="250.0" 
           prefHeight="350.0" 
           styleClass="xk-table">
   <columns>
      <TableColumn fx:id="colSTT" maxWidth="50.0" minWidth="50.0" text="STT" />
      <TableColumn fx:id="colTenThuoc" minWidth="300.0" text="TÊN THUỐC" />
      <TableColumn fx:id="colSoLo" maxWidth="150.0" minWidth="150.0" text="SỐ LÔ" />
      <TableColumn fx:id="colSoLuong" maxWidth="100.0" minWidth="100.0" text="SL CHUYỂN" />
      <TableColumn fx:id="colXoa" maxWidth="60.0" minWidth="60.0" text="XÓA" />
   </columns>
   <columnResizePolicy>
      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
   </columnResizePolicy>
</TableView>

            <VBox spacing="3.0">
                <Label styleClass="input-label-title" text="Ghi chú phiếu chuyển:" />
                <TextField fx:id="txtGhiChu" prefHeight="35.0" promptText="Nhập lý do chuyển..." styleClass="input-field" />
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <Button onAction="#handleHuyBo" prefHeight="40.0" prefWidth="120.0" styleClass="btn-cancel" text="Hủy Bỏ" />
               <Button onAction="#handleXacNhanChuyen" prefHeight="40.0" prefWidth="260.0" styleClass="btn-success" text="✔ XÁC NHẬN CHUYỂN KHO" />
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
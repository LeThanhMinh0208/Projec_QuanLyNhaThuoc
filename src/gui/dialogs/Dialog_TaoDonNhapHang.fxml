<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="820.0" prefWidth="1280.0" spacing="20.0" styleClass="dmk-main-bg" stylesheets="@../../resources/css/QuanLyDonNhapHang.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_TaoDonNhapHangController">
   <padding>
      <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Label styleClass="dmk-page-title" text="📝 LẬP ĐƠN ĐẶT HÀNG MỚI" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT">
               <children>
                  <Label text="MÃ ĐƠN HÀNG" textFill="#64748b">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <Label fx:id="lblMaDon" text="DDH0000" textFill="#0284c7">
                     <font><Font name="System Bold" size="22.0" /></font>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>

      <HBox spacing="25.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox prefWidth="420.0" spacing="15.0" styleClass="dmk-card">
               <children>
                  <Label text="📦 Danh Mục Thuốc Cần Đặt" style="-fx-font-weight: bold; -fx-text-fill: #0284c7; -fx-font-size: 16px;" />
                  
                  <HBox styleClass="dmk-search-wrapper" prefHeight="45.0" alignment="CENTER_LEFT">
                     <padding><Insets left="15.0" right="15.0" /></padding>
                     <children>
                        <Label text="🔍" style="-fx-font-size: 16px; -fx-text-fill: #0284c7;"/>
                        <TextField fx:id="txtTimThuoc" promptText="Nhập tên thuốc..." styleClass="dmk-search-field" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  
                  <ListView fx:id="listViewThuoc" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;" />
                  
                  <VBox spacing="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10;">
                     <children>
                        <GridPane vgap="15.0" hgap="10.0">
                           <columnConstraints>
                              <ColumnConstraints prefWidth="80.0" />
                              <ColumnConstraints hgrow="ALWAYS" />
                           </columnConstraints>
                           <children>
                              <Label text="Quy cách:" style="-fx-font-weight: bold;" />
                              <ComboBox fx:id="cmbDonVi" maxWidth="Infinity" promptText="Chọn quy cách đóng gói" GridPane.columnIndex="1" />
                              
                              <Label text="Số lượng:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" />
                              <Spinner fx:id="spnSoLuong" maxWidth="Infinity" editable="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                           </children>
                        </GridPane>
                        <Button onAction="#handleThemVaoDon" prefHeight="45.0" maxWidth="Infinity" styleClass="btn-action, btn-nhap" text="➕ ĐƯA VÀO ĐƠN HÀNG" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <VBox spacing="15.0" HBox.hgrow="ALWAYS" styleClass="dmk-card">
               <children>
                  <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                      <ColumnConstraints prefWidth="110.0" />
                      <ColumnConstraints hgrow="ALWAYS" />
                      <ColumnConstraints prefWidth="110.0" />
                      <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Nhà cung cấp:" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="cmbNhaCungCap" maxWidth="Infinity" promptText="-- Chọn Nhà Cung Cấp --" style="-fx-font-size: 14px; -fx-pref-height: 40px;" GridPane.columnIndex="1" />
                        
                        <Label text="Ngày hẹn giao:" style="-fx-font-weight: bold;" GridPane.columnIndex="2" />
                        <DatePicker fx:id="dpNgayHenGiao" maxWidth="Infinity" promptText="DD/MM/YYYY" style="-fx-font-size: 14px; -fx-pref-height: 40px;" GridPane.columnIndex="3" />
                        
                        <Label text="Ghi chú đơn:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" />
                        <TextField fx:id="txtGhiChu" promptText="Yêu cầu thêm cho nhà cung cấp (nếu có)..." style="-fx-font-size: 14px; -fx-pref-height: 40px;" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="1" />
                    </children>
                  </GridPane>

                  <TableView fx:id="tableChiTietDon" styleClass="dmk-table" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colTenThuoc" prefWidth="250.0" text="Tên Thuốc / Hoạt Chất" />
                      <TableColumn fx:id="colDonVi" prefWidth="100.0" text="Quy Cách" />
                      <TableColumn fx:id="colSoLuong" prefWidth="90.0" text="SL Đặt" />
                      <TableColumn fx:id="colGiaDuKien" prefWidth="130.0" text="Đơn Giá (Dự kiến)" />
                      <TableColumn fx:id="colThanhTien" prefWidth="150.0" text="Thành Tiền" />
                    </columns>
                  </TableView>

                  <HBox alignment="CENTER_RIGHT" spacing="20.0">
                     <children>
                        <Label text="TỔNG TIỀN DỰ TÍNH:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                        <Label fx:id="lblTongTien" text="0 VNĐ" textFill="#f59e0b">
                           <font><Font name="System Bold" size="26.0" /></font>
                        </Label>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10 0 0 0;">
                     <children>
                        <Button onAction="#handleDongDialog" prefHeight="50.0" prefWidth="150.0" styleClass="btn-action, btn-xoa" style="-fx-background-color: #94a3b8;" text="Hủy Bỏ" />
                        <Button onAction="#handleTaoDonHang" prefHeight="50.0" prefWidth="250.0" styleClass="btn-action, btn-them" text="🚀 XÁC NHẬN ĐẶT HÀNG" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" prefWidth="1120" prefHeight="760" fx:controller="gui.dialogs.Dialog_ChiTietDoiTraController"
            style="-fx-background-color:transparent; -fx-background:transparent;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox prefWidth="1080" spacing="16"
              style="-fx-background-color:#f8fafc; -fx-padding:24;">

            <stylesheets>
                <URL value="@../../resources/css/TrangChu.css" />
                <URL value="@../../resources/css/BanHang.css" />
            </stylesheets>

            <VBox styleClass="bh-panel" spacing="10">
                <Label text="THÔNG TIN HÓA ĐƠN ĐỔI TRẢ" styleClass="bh-section-title" />
                <GridPane hgap="20" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="130" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints prefWidth="130" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <Label text="Mã hóa đơn:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <Label fx:id="lblMaHD" style="-fx-font-weight:bold; -fx-text-fill:#0f172a;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                    <Label text="Ngày lập:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                    <Label fx:id="lblNgayLap" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                    <Label text="Khách hàng:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <Label fx:id="lblKhachHang" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                    <Label text="Nhân viên:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                    <Label fx:id="lblNhanVien" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="1" GridPane.columnIndex="3" />

                    <Label text="Tổng thanh toán:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <Label fx:id="lblTongHoaDon" style="-fx-text-fill:#0f172a; -fx-font-weight:bold;" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                    <Label text="Hình thức TT:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="2" GridPane.columnIndex="2" />
                    <Label fx:id="lblHinhThuc" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="2" GridPane.columnIndex="3" />
                </GridPane>
            </VBox>

            <VBox styleClass="bh-panel" spacing="8" VBox.vgrow="ALWAYS">
                <Label text="MẶT HÀNG CÓ THỂ ĐỔI TRẢ" styleClass="bh-section-title" />
                <TableView fx:id="tableCoTheDoiTra" minHeight="220" prefHeight="220" VBox.vgrow="ALWAYS"
                           style="-fx-text-background-color:#0f172a; -fx-control-inner-background:white; -fx-table-cell-border-color:#e2e8f0;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="Không có mặt hàng nào có thể đổi trả" style="-fx-text-fill:#64748b; -fx-font-size:14px;" />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colHangTenThuoc" text="Tên thuốc" prefWidth="220" />
                        <TableColumn fx:id="colHangDonVi" text="Đơn vị" prefWidth="90" />
                        <TableColumn fx:id="colHangLo" text="Lô thuốc" prefWidth="110" />
                        <TableColumn fx:id="colHangHSD" text="HSD" prefWidth="110" />
                        <TableColumn fx:id="colHangDaMua" text="Đã mua" prefWidth="80" />
                        <TableColumn fx:id="colHangDaTra" text="Đã trả" prefWidth="80" />
                        <TableColumn fx:id="colHangConLai" text="Còn lại" prefWidth="80" />
                        <TableColumn fx:id="colHangDonGia" text="Đơn giá" prefWidth="110" />
                    </columns>
                </TableView>
            </VBox>

            <VBox styleClass="bh-panel" spacing="12" VBox.vgrow="NEVER">
                <Label text="THÊM CHI TIẾT ĐỔI TRẢ" styleClass="bh-section-title" />
                <GridPane hgap="16" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints prefWidth="120" />
                        <ColumnConstraints prefWidth="180" />
                    </columnConstraints>
                    <Label text="Số lượng trả:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <TextField fx:id="txtSoLuongTra" promptText="Nhập số lượng" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                    <Label text="Hình thức xử lý:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                    <ComboBox fx:id="cbHinhThucXuLy" prefWidth="180" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                    <Label text="Tình trạng:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <TextField fx:id="txtTinhTrang" promptText="Ví dụ: còn nguyên seal" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3" />

                    <Label text="Lý do:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <TextArea fx:id="txtLyDo" prefRowCount="2" wrapText="true" promptText="Nhập lý do đổi trả" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3" />

                    <HBox alignment="CENTER_RIGHT" spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="2" GridPane.columnSpan="2">
                        <Button text="Thêm vào phiếu" onAction="#handleThemChiTiet" styleClass="bh-btn-secondary" prefHeight="36" />
                    </HBox>
                </GridPane>
            </VBox>

            <VBox styleClass="bh-panel" spacing="8" VBox.vgrow="ALWAYS">
                <Label text="CHI TIẾT PHIẾU ĐỔI TRẢ" styleClass="bh-section-title" />
                <TableView fx:id="tableChiTietDoiTra" minHeight="220" prefHeight="220" VBox.vgrow="ALWAYS"
                           style="-fx-text-background-color:#0f172a; -fx-control-inner-background:white; -fx-table-cell-border-color:#e2e8f0;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="Chưa có chi tiết đổi trả nào" style="-fx-text-fill:#64748b; -fx-font-size:14px;" />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colCTTenThuoc" text="Tên thuốc" prefWidth="220" />
                        <TableColumn fx:id="colCTDonVi" text="Đơn vị" prefWidth="90" />
                        <TableColumn fx:id="colCTLo" text="Lô thuốc" prefWidth="110" />
                        <TableColumn fx:id="colCTSoLuong" text="Số lượng trả" prefWidth="90" />
                        <TableColumn fx:id="colCTTinhTrang" text="Tình trạng" prefWidth="220" />
                        <TableColumn fx:id="colCTThanhTien" text="Tiền hoàn" prefWidth="120" />
                        <TableColumn fx:id="colCTHanhDong" text="Hành động" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>

            <VBox styleClass="bh-panel" spacing="8" VBox.vgrow="NEVER">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Tổng số mặt hàng:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" />
                    <Label fx:id="lblTongDong" style="-fx-text-fill:#0f172a;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Tổng tiền hoàn:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" />
                    <Label fx:id="lblTongTienHoan" style="-fx-text-fill:#16a34a; -fx-font-size:18px; -fx-font-weight:bold;" />
                </HBox>
                <Separator />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button text="Đóng" onAction="#handleDong" styleClass="bh-btn-secondary" prefHeight="40" prefWidth="100" />
                    <Button text="Lưu phiếu đổi trả" onAction="#handleLuu" styleClass="bh-btn-primary" prefHeight="40" prefWidth="180" />
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>

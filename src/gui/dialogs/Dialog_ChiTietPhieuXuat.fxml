<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="950.0" prefHeight="650.0" spacing="20.0" style="-fx-background-color: white;" stylesheets="@../../resources/css/XuatKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_ChiTietPhieuXuatController">
   <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0ea5e9;" text="📄 " />
            <Label fx:id="lblLoaiPhieu" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0ea5e9;" text="CHI TIẾT PHIẾU" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblNgayLap" style="-fx-font-size: 14px; -fx-text-fill: #64748b;" text="--/--/---- --:--" />
         </children>
      </HBox>

      <GridPane hgap="25.0" vgap="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
         <columnConstraints>
            <ColumnConstraints percentWidth="33.0" />
            <ColumnConstraints percentWidth="33.0" />
            <ColumnConstraints percentWidth="34.0" />
         </columnConstraints>
         <children>
            <VBox spacing="5.0" GridPane.columnIndex="0">
               <Label style="-fx-text-fill: #64748b; -fx-font-weight: bold;" text="Mã Phiếu:" />
               <Label fx:id="lblMaPhieu" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="---" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1">
               <Label style="-fx-text-fill: #64748b; -fx-font-weight: bold;" text="Người Lập:" />
               <Label fx:id="lblNguoiLap" style="-fx-font-size: 15px;" text="---" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="2">
               <Label style="-fx-text-fill: #64748b; -fx-font-weight: bold;" text="Người Vận Chuyển:" />
               <Label fx:id="lblNguoiVanChuyen" style="-fx-font-size: 15px; -fx-text-fill: #0369a1; -fx-font-weight: bold;" text="---" />
            </VBox>
            
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
               <Label style="-fx-text-fill: #64748b; -fx-font-weight: bold;" text="Nơi Xuất:" />
               <Label fx:id="lblNoiXuat" style="-fx-font-size: 15px; -fx-text-fill: #b91c1c;" text="---" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <Label style="-fx-text-fill: #64748b; -fx-font-weight: bold;" text="Nơi Nhận:" />
               <Label fx:id="lblNoiNhan" style="-fx-font-size: 15px; -fx-text-fill: #15803d;" text="---" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
               <Label style="-fx-text-fill: #64748b; -fx-font-weight: bold;" text="Ghi chú:" />
               <Label fx:id="lblGhiChu" wrapText="true" style="-fx-font-size: 14px; -fx-font-style: italic;" text="---" />
            </VBox>
         </children>
      </GridPane>

      <TableView fx:id="tableChiTiet" styleClass="xk-table" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colSTT" prefWidth="50.0" text="STT" />
            <TableColumn fx:id="colTenThuoc" prefWidth="250.0" text="TÊN THUỐC" />
            <TableColumn fx:id="colSoLo" prefWidth="120.0" text="SỐ LÔ" />
            <TableColumn fx:id="colSoLuong" prefWidth="100.0" text="SỐ LƯỢNG" />
            <TableColumn fx:id="colDonGia" prefWidth="120.0" text="ĐƠN GIÁ" />
            <TableColumn fx:id="colThanhTien" prefWidth="150.0" text="THÀNH TIỀN" />
         </columns>
         <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
      </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="20.0">
         <Label fx:id="lblTextTongTien" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Tổng giá trị:" />
         <Label fx:id="lblTongTien" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="0 VNĐ" />
         <Region HBox.hgrow="ALWAYS" />
         
         <Button onAction="#handleInPhieu" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🖨 IN PHIẾU PDF" />
         
         <Button onAction="#handleDong" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="ĐÓNG CỬA SỔ" />
      </HBox>
   </children>
</VBox>
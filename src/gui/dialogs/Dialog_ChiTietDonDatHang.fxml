<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="750.0" prefWidth="1200.0" styleClass="dialog-root" stylesheets="@../../resources/css/QuanLyDonDatHang.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_ChiTietDonDatHangController">
   <children>
      <HBox alignment="CENTER_LEFT" styleClass="dialog-header-area">
         <children>
            <Label text="✨ CHI TIẾT ĐƠN ĐẶT HÀNG" styleClass="dialog-title-text" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblMaDon" text="Mã đơn: DDH001" styleClass="dialog-subtitle-text" />
         </children>
      </HBox>

      <VBox spacing="25.0" VBox.vgrow="ALWAYS">
         <padding><Insets bottom="25.0" left="30.0" right="30.0" top="25.0" /></padding>
         <children>
            
            <GridPane hgap="20.0" vgap="15.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="110.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="110.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <Label text="Nhà cung cấp:" styleClass="dialog-info-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <Label fx:id="lblNhaCungCap" text="Tên Cty" styleClass="dialog-info-value-box" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity" />
                  
                  <Label text="Người lập đơn:" styleClass="dialog-info-label" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <Label fx:id="lblNhanVien" text="Nguyễn Văn A" styleClass="dialog-info-value-box" GridPane.columnIndex="3" GridPane.rowIndex="0" maxWidth="Infinity" />

                  <Label text="Ngày đặt hàng:" styleClass="dialog-info-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <Label fx:id="lblNgayLap" text="20/10/2026" styleClass="dialog-info-value-box" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" />
                  
                  <Label text="Ghi chú:" styleClass="dialog-info-label" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <Label fx:id="lblGhiChu" text="---" styleClass="dialog-info-value-box" GridPane.columnIndex="3" GridPane.rowIndex="1" maxWidth="Infinity" />
               </children>
            </GridPane>

            <VBox styleClass="dmk-card" VBox.vgrow="ALWAYS">
               <children>
                  <TableView fx:id="tableChiTiet" styleClass="dmk-table" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colTenThuoc" prefWidth="200.0" text="TÊN THUỐC" />
                      <TableColumn fx:id="colDonVi" prefWidth="80.0" text="ĐƠN VỊ" />
                      <TableColumn fx:id="colSoLuongDat" prefWidth="80.0" text="SL ĐẶT" />
                      <TableColumn fx:id="colSoLuongNhan" prefWidth="90.0" text="SL NHẬN" />
                      <TableColumn fx:id="colMaLo" prefWidth="100.0" text="MÃ LÔ" />
                      <TableColumn fx:id="colHanDung" prefWidth="100.0" text="HẠN DÙNG" />
                      <TableColumn fx:id="colGiaNhap" prefWidth="120.0" text="GIÁ DỰ KIẾN" />
                      <TableColumn fx:id="colThanhTien" prefWidth="130.0" text="THÀNH TIỀN" />
                      <TableColumn fx:id="colTinhTrang" prefWidth="120.0" text="TÌNH TRẠNG" />
                      <TableColumn fx:id="colTienDo" prefWidth="120.0" text="TIẾN ĐỘ" />
                    </columns>
                     <columnResizePolicy><TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                  </TableView>
               </children>
               <padding><Insets bottom="5.0" left="5.0" right="5.0" top="5.0" /></padding>
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="20.0">
               <children>
                  <Label text="Tổng tiền dự kiến:" styleClass="dialog-info-label" style="-fx-font-size: 16px;" />
                  <Label fx:id="lblTongTienDuKien" text="0 VNĐ" styleClass="text-total-price" />
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <Button onAction="#handleDong" prefHeight="45.0" prefWidth="130.0" styleClass="btn-close" text="Đóng" />
                  <Button fx:id="btnHuyDon" onAction="#handleHuyDon" prefHeight="45.0" prefWidth="130.0" styleClass="btn-danger" text="Hủy Đơn" />
                  <Button onAction="#handleInDonHang" prefHeight="45.0" prefWidth="150.0" styleClass="btn-print" text="IN PHIẾU ✨" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox prefWidth="780.0" prefHeight="600.0" spacing="0"
      stylesheets="@../../resources/css/BanHang.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialogs.Dialog_ChonThuocController">

    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
    </stylesheets>

    <!-- ── HEADER ── -->
    <HBox styleClass="dialog-header" spacing="10" alignment="CENTER_LEFT">
        <children>
            <Label text="CHỌN THUỐC KÊ ĐƠN" styleClass="dialog-header-title"/>
        </children>
    </HBox>

    <!-- ── BODY ── -->
    <VBox spacing="12" styleClass="dialog-body" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="12" right="16" bottom="12" left="16" />
        </padding>

        <!-- Phần tìm kiếm + badge -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <children>
                <HBox alignment="CENTER_LEFT" styleClass="search-box" prefHeight="42" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="search-icon" text="🔍" />
                        <TextField fx:id="txtTim" prefHeight="40"
                                   promptText="Tìm tên thuốc, hoạt chất, mã thuốc..."
                                   styleClass="search-input" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <Label fx:id="lblBadgeKeDon" text="🔵 Thuốc kê đơn = nền xanh"
                       style="-fx-text-fill: #1565C0; -fx-font-size: 11px; -fx-font-style: italic;"/>
            </children>
        </HBox>

        <!-- Phần danh sách thuốc — ListView với custom cell -->
        <ListView fx:id="listThuoc" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-border-width: 1;">
        </ListView>

        <!-- Phần thông tin thuốc -->
        <HBox spacing="12" alignment="CENTER"
              style="-fx-background-color: #f0f9ff; -fx-background-radius: 10; -fx-padding: 12 16;">
            <children>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTonInfo" text="Tồn: —"
                       style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label fx:id="lblGiaInfo" text="Giá: —"
                       style="-fx-text-fill: #16a34a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </children>
        </HBox>
    </VBox>

    <!-- ── FOOTER ── -->
    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
        <children>
            <Button text="Hủy" onAction="#handleHuy" styleClass="dialog-btn-cancel"
                    prefWidth="100" prefHeight="42"/>
            <Button fx:id="btnThemVaoGio" text="✔️ Chọn thuốc" onAction="#handleChon"
                    styleClass="dialog-btn-ok" prefWidth="160" prefHeight="42"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 6px;"/>
        </children>
    </HBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<VBox prefWidth="560.0" spacing="0" stylesheets="@../../resources/css/BanHang.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialogs.Dialog_ChonSoLuongDonViController">

    <children>
        <!-- ── HEADER ── -->
        <HBox styleClass="dialog-header" spacing="15" alignment="CENTER_LEFT">
            <children>
                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 5; -fx-background-radius: 8;">
                    <children>
                        <ImageView fx:id="imgThuoc" fitHeight="70" fitWidth="70" preserveRatio="true"/>
                    </children>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Chọn đơn vị &amp; số lượng" styleClass="dialog-header-title"/>
                        <Label fx:id="lblTenThuoc" text="" styleClass="dialog-header-sub" wrapText="true" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- ── BODY ── -->
        <VBox styleClass="dialog-body" spacing="16">
            <children>
                <!-- Đơn vị -->
                <VBox spacing="6">
                    <children>
                        <Label text="Đơn vị bán" styleClass="dialog-label"/>
                        <ComboBox fx:id="cbDonVi" prefHeight="42" maxWidth="Infinity"
                                  styleClass="dialog-combo"/>
                    </children>
                </VBox>

                <!-- Số lượng -->
                <VBox spacing="6">
                    <children>
                        <Label text="Số lượng" styleClass="dialog-label"/>
                        <Spinner fx:id="spSoLuong" prefHeight="52" maxWidth="Infinity"
                                 editable="true"/>
                    </children>
                </VBox>

                <!-- Tồn kho -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color: #f0f9ff; -fx-background-radius: 12; -fx-padding: 14 20;">
                    <children>
                        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Tồn khả dụng" styleClass="dialog-label"/>
                                <HBox alignment="CENTER" spacing="6">
                                    <children>
                                        <Label fx:id="lblTon" text="0" styleClass="dialog-ton-label"/>
                                        <Label fx:id="lblTonUnit" text="đơn vị" styleClass="dialog-ton-unit"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Cảnh báo số lượng -->
                <Label fx:id="lblCanhBao" text="" styleClass="dialog-warn" wrapText="true"/>

                <!-- Giá bán (tự động từ bảng giá) -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #f0fdf4; -fx-background-radius: 10; -fx-padding: 10 16;">
                    <children>
                        <Label text="🏷 Đơn giá:" style="-fx-text-fill: #374151; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblDonGia" text="—" HBox.hgrow="ALWAYS"
                               style="-fx-text-fill: #6b7280; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- ── FOOTER ── -->
        <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button text="Hủy" onAction="#handleHuy" styleClass="dialog-btn-cancel" prefWidth="120" prefHeight="44"/>
                <Button fx:id="btnDongY" text="Thêm vào giỏ" onAction="#handleDongY" styleClass="dialog-btn-ok" prefWidth="180" prefHeight="44"/>
            </children>
        </HBox>
    </children>
</VBox>

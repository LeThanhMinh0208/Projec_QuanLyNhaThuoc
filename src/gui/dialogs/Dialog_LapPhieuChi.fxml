<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="580.0" spacing="0.0" styleClass="dialog-container" stylesheets="@../../resources/css/QuanLyCongNo.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_LapPhieuChiController">
   <children>
      <VBox styleClass="dialog-header-area" spacing="5">
         <children>
            <Label styleClass="dialog-title" text="✨ LẬP PHIẾU CHI TIỀN MỚI" />
            <Label text="Vui lòng kiểm tra kỹ thông tin trước khi xác nhận" style="-fx-text-fill: #e0f2fe; -fx-font-size: 13px;" />
         </children>
      </VBox>

      <VBox spacing="20.0" style="-fx-padding: 30;">
         <children>
            <GridPane hgap="20.0" vgap="20.0">
               <columnConstraints>
                  <ColumnConstraints minWidth="130.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>
               <children>
                  <Label styleClass="dialog-label-static" text="Nhà Cung Cấp:" GridPane.rowIndex="0" />
                  <Label fx:id="lblTenNCC" styleClass="dialog-value-text" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                  <Label styleClass="dialog-label-static" text="Công nợ hiện tại:" GridPane.rowIndex="1" />
                  <Label fx:id="lblCongNo" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #e11d48;" text="0 VNĐ" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label styleClass="dialog-label-static" text="Số tiền chi (*):" GridPane.rowIndex="2" />
                  <VBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                     <children>
                        <TextField fx:id="txtSoTien" prefHeight="45.0" promptText="0.0" styleClass="dialog-input-field" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                        <CheckBox fx:id="chkTatToan" style="-fx-text-fill: #059669; -fx-font-weight: bold;" text="✔ Thanh toán hết toàn bộ nợ" />
                     </children>
                  </VBox>

                  <Label styleClass="dialog-label-static" text="Hình thức chi:" GridPane.rowIndex="3" />
                  <ComboBox fx:id="cbHinhThuc" prefHeight="40.0" prefWidth="250.0" styleClass="dialog-input-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                  <Label styleClass="dialog-label-static" text="Ghi chú:" GridPane.rowIndex="4" />
                  <TextArea fx:id="txtGhiChu" prefRowCount="3" promptText="Nội dung chi tiền (Ví dụ: Trả nợ tháng 3)..." styleClass="dialog-input-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
               </children>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
               <children>
                  <Button fx:id="btnHuy" onAction="#handleHuy" prefHeight="45.0" prefWidth="120.0" styleClass="btn-dialog-cancel" text="Hủy" />
                  <Button onAction="#handleXacNhan" prefHeight="45.0" prefWidth="220.0" styleClass="btn-dialog-save" text="LƯU PHIẾU CHI ✨" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
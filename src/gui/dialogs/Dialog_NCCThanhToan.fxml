<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="600.0" spacing="0.0" styleClass="dialog-container" stylesheets="@../../resources/css/QuanLyCongNo.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialogs.Dialog_NCCThanhToanController">
   <children>
      <VBox spacing="5" style="-fx-background-color: linear-gradient(to right, #059669, #10b981); -fx-padding: 25px; -fx-background-radius: 15px 15px 0 0;">
         <children>
            <Label styleClass="dialog-title" text="💵 NCC THANH TOÁN" />
            <Label text="Xác nhận số tiền Nhà cung cấp thanh toán lại cho cửa hàng" style="-fx-text-fill: #ecfdf5; -fx-font-size: 13px;" />
         </children>
      </VBox>

      <VBox spacing="20.0" style="-fx-padding: 30;">
         <children>
            <GridPane hgap="20.0" vgap="20.0">
               <columnConstraints>
                  <ColumnConstraints minWidth="150.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>
               <children>
                  <Label styleClass="dialog-label-static" text="Nhà Cung Cấp:" GridPane.rowIndex="0" />
                  <Label fx:id="lblTenNCC" styleClass="dialog-value-text" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                  <Label styleClass="dialog-label-static" text="Tiền NCC đang nợ:" GridPane.rowIndex="1" />
                  <Label fx:id="lblCongNoNCCNo" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #10b981;" text="0 VNĐ" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label styleClass="dialog-label-static" text="Số tiền thu vào (*):" GridPane.rowIndex="2" />
                  <VBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                     <children>
                        <TextField fx:id="txtSoTienThu" prefHeight="45.0" promptText="0.0" styleClass="dialog-input-field" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                        <CheckBox fx:id="chkTatToan" style="-fx-text-fill: #0ea5e9; -fx-font-weight: bold;" text="✔ Thu đủ toàn bộ số nợ" />
                     </children>
                  </VBox>

                  <Label styleClass="dialog-label-static" text="Hình thức thu:" GridPane.rowIndex="3" />
                  <ComboBox fx:id="cbHinhThuc" prefHeight="40.0" prefWidth="250.0" styleClass="dialog-input-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                  <Label styleClass="dialog-label-static" text="Ghi chú:" GridPane.rowIndex="4" />
                  <TextArea fx:id="txtGhiChu" prefRowCount="3" promptText="Nội dung thu tiền (Ví dụ: NCC hoàn tiền trả hàng)..." styleClass="dialog-input-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
               </children>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
               <children>
                  <Button fx:id="btnHuy" onAction="#handleHuy" prefHeight="45.0" prefWidth="120.0" styleClass="btn-dialog-cancel" text="Hủy" />
                  <Button onAction="#handleXacNhan" prefHeight="45.0" prefWidth="260.0" style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25px; -fx-cursor: hand;" text="XÁC NHẬN ĐÃ THANH TOÁN ✔" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
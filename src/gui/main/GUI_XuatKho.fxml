<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="850.0" prefWidth="1200.0" spacing="25.0" styleClass="xk-main-bg" stylesheets="@../../resources/css/XuatKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_XuatKhoController">
   <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
   
   <children>
      <VBox spacing="8.0">
         <Label styleClass="xk-page-title" text="QUẢN LÝ XUẤT KHO" />
         <Region maxWidth="400.0" styleClass="xk-title-line" />
      </VBox>

      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Button maxWidth="Infinity" minWidth="0.0" onAction="#handleMoDialogChuyenKho" prefHeight="70.0" styleClass="btn-color-1" text="🚚 Lệnh Chuyển Kho" HBox.hgrow="ALWAYS" />
            
            <Button maxWidth="Infinity" minWidth="0.0" onAction="#handleMoDialogTraNCC" prefHeight="70.0" styleClass="btn-color-2" text="🔙 Trả Nhà Cung Cấp" HBox.hgrow="ALWAYS" />
            
            <Button maxWidth="Infinity" minWidth="0.0" onAction="#handleMoDialogXuatHuy" prefHeight="70.0" styleClass="btn-color-3" text="🗑 Lệnh Xuất Hủy" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <VBox spacing="20.0" styleClass="xk-card" VBox.vgrow="ALWAYS">
         <padding><Insets bottom="20.0" left="25.0" right="25.0" top="25.0" /></padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <Label styleClass="danh-muc-title" text="Danh Mục Phiếu Xuất" />
               <Region HBox.hgrow="ALWAYS" />
               
             <ComboBox fx:id="cbLocLoaiPhieu" prefHeight="45.0" prefWidth="180.0" promptText="Lọc theo loại phiếu" styleClass="xk-input" />
<DatePicker fx:id="dpTuNgay" prefHeight="45.0" prefWidth="150.0" promptText="Từ ngày" styleClass="xk-input" />
<DatePicker fx:id="dpDenNgay" prefHeight="45.0" prefWidth="150.0" promptText="Đến ngày" styleClass="xk-input" />

               <HBox alignment="CENTER_LEFT" prefHeight="45.0" prefWidth="300.0" styleClass="xk-search-wrapper">
                  <children>
                     <Label style="-fx-text-fill: #0ea5e9; -fx-font-size: 16px;" text="🔍 " />
                     <TextField fx:id="txtTimPhieu" promptText="Tìm mã phiếu, người lập..." styleClass="xk-search-field" HBox.hgrow="ALWAYS" />
                  </children>
               </HBox>
            </HBox>

<TableView fx:id="tableDanhMucPhieuXuat" styleClass="xk-table" VBox.vgrow="ALWAYS">
   <columns>
      <TableColumn fx:id="colSTT" prefWidth="50.0" text="STT" />
      <TableColumn fx:id="colMaPhieu" prefWidth="120.0" text="MÃ PHIẾU" />
      <TableColumn fx:id="colThoiGian" prefWidth="160.0" text="THỜI GIAN LẬP" />
      <TableColumn fx:id="colLoaiPhieu" prefWidth="160.0" text="LOẠI PHIẾU" />
      <TableColumn fx:id="colNguoiLap" prefWidth="180.0" text="NGƯỜI LẬP" />
      <TableColumn fx:id="colKhoNhan" prefWidth="280.0" text="NƠI NHẬN" /> 
      <TableColumn fx:id="colThaoTac" prefWidth="100.0" text="THAO TÁC" /> 
   </columns>
   <columnResizePolicy>
      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
   </columnResizePolicy>
</TableView>
         </children>
      </VBox>
   </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="25.0" styleClass="khachhang-main-bg" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.main.GUI_QuanLyKhachHangController">

    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
        <URL value="@../../resources/css/QuanLyKhachHang.css" />
    </stylesheets>

    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
            <children>
                <Label styleClass="main-title" text="QUẢN LÝ KHÁCH HÀNG" />
                <Region maxWidth="Infinity" styleClass="xk-title-line" />
            </children>
        </VBox>
    </HBox>

    <GridPane hgap="20" maxWidth="Infinity">
         <columnConstraints>
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.34" hgrow="ALWAYS" />
         </columnConstraints>
         <children>
            <Button fx:id="btnThem" maxWidth="Infinity" minHeight="50" prefHeight="50" graphicTextGap="10" onAction="#handleThem" styleClass="top-card, card-green" text="Thêm mới" GridPane.columnIndex="0">
                <graphic>
                  <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../resources/icons/plus.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
            
            <Button fx:id="btnSua" maxWidth="Infinity" minHeight="50" prefHeight="50" graphicTextGap="10" onAction="#handleSua" styleClass="top-card, card-blue" text="Cập nhật" GridPane.columnIndex="1">
                <graphic>
                  <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../resources/icons/fix.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
            
            <Button fx:id="btnXoa" maxWidth="Infinity" minHeight="50" prefHeight="50" graphicTextGap="10" onAction="#handleXoa" styleClass="top-card, card-orange" text="Xóa" GridPane.columnIndex="2">
                <graphic>
                  <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../resources/icons/minus.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
         </children>
    </GridPane>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="45.0" styleClass="search-box" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="search-icon" text="🔍" />
                  <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm theo tên, số điện thoại..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                  <Button text="Làm mới" onAction="#handleLamMoiTK" styleClass="bh-btn-secondary" prefHeight="32"/>
               </children>
            </HBox>
         </children>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white">
        <TableView fx:id="tableKhachHang" VBox.vgrow="ALWAYS" styleClass="table-view" style="-fx-fixed-cell-size: 50;">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            <placeholder>
                <Label text="Không có dữ liệu khách hàng" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colMa" text="Mã KH" prefWidth="120" style="-fx-alignment: CENTER; -fx-font-weight: bold;" />
                <TableColumn fx:id="colHoTen" text="Họ Tên" prefWidth="250" />
                <TableColumn fx:id="colSdt" text="Số Điện Thoại" prefWidth="150" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDiaChi" text="Địa Chỉ" prefWidth="300" />
                <TableColumn fx:id="colDiem" text="Điểm Tích Lũy" prefWidth="120" style="-fx-alignment: CENTER; -fx-text-fill: #0ea5e9; -fx-font-weight: bold;" />
            </columns>
        </TableView>
    </VBox>
</VBox>
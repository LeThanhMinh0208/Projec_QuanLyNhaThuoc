<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Region?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="25.0" styleClass="main-bg" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.main.GUI_QuanLyKhachHangController">

    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
    </stylesheets>

    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
            <children>
                <Label styleClass="main-title" text="QUẢN LÝ KHÁCH HÀNG" />
                <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
            </children>
        </VBox>
    </HBox>

    <!-- Action Buttons -->
    <GridPane hgap="8" maxWidth="Infinity">
         <columnConstraints>
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.34" hgrow="ALWAYS" />
         </columnConstraints>
         <children>
            <Button fx:id="btnThem" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleThem" styleClass="top-card, card-green, btn-action" text="＋ Thêm mới" textFill="WHITE" GridPane.columnIndex="0" />
            
            <Button fx:id="btnSua" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleSua" styleClass="top-card, card-blue, btn-action" text="✎ Cập nhật" textFill="WHITE" GridPane.columnIndex="1" />
            
            <Button fx:id="btnXoa" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleXoa" styleClass="top-card, card-orange, btn-action" text="✖ Xóa" textFill="WHITE" GridPane.columnIndex="2" />
         </children>
    </GridPane>

    <!-- Search Box -->
    <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="45.0" styleClass="search-box" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="search-icon" text="🔍" />
                  <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm theo tên, số điện thoại..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                  <Button text="Làm mới" onAction="#handleLamMoiTK" styleClass="bh-btn-secondary" prefHeight="32"/>
               </children>
            </HBox>
         </children>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white">
        <TableView fx:id="tableKhachHang" VBox.vgrow="ALWAYS" styleClass="table-view" style="-fx-fixed-cell-size: 36;">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            <placeholder>
                <Label text="Không có dữ liệu khách hàng" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colMa" text="Mã KH" prefWidth="120" />
                <TableColumn fx:id="colHoTen" text="Họ Tên" prefWidth="250" />
                <TableColumn fx:id="colSdt" text="Số Điện Thoại" prefWidth="150" />
                <TableColumn fx:id="colDiaChi" text="Địa Chỉ" prefWidth="300" />
                <TableColumn fx:id="colDiem" text="Điểm Tích Lũy" prefWidth="120" />
            </columns>
        </TableView>
    </VBox>

</VBox>
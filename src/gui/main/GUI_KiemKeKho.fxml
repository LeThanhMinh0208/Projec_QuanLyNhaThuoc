<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="850.0" prefWidth="1200.0" spacing="20.0" styleClass="main-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_KiemKeKhoController">
    <stylesheets><URL value="@../../resources/css/KiemKeKho.css" />
     <URL value="@../../resources/css/TrangChu.css" /></stylesheets>
    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding> 
       <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
          <children>
              <Label styleClass="main-title" text="LẬP PHIẾU &amp; ĐẾM KHO" />
              <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
          </children>
      </VBox>

    <StackPane VBox.vgrow="ALWAYS">
        <VBox fx:id="viewLapPhieu" spacing="15">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <MenuButton fx:id="mbNhomThuoc" text="✨Chọn Nhóm Thuốc" styleClass="btn-green" prefHeight="40" prefWidth="230" />
                <Button text="⚡ Kiểm Thông Minh" onAction="#handleKiemKeThongMinh" styleClass="btn-blue" prefHeight="40" prefWidth="230" />
                <Button text="✔ Kiểm Tất Cả" onAction="#handleKiemTatCa" styleClass="btn-orange" prefHeight="40" prefWidth="230" />
                
                <Button text="📂 Import CSV" onAction="#handleImportCSVChonThuoc" styleClass="btn-yellow" prefHeight="40" prefWidth="230" />
                
                <HBox HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" styleClass="kk-search-wrapper" prefHeight="40.0" prefWidth="300">
                    <Label style="-fx-text-fill:#0ea5e9;" text="🔍" />
                    <TextField fx:id="txtTimKiemThuoc" promptText="Tìm lô thuốc, tên thuốc..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                </HBox>
            </HBox>
            <VBox styleClass="panel-white" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableChonThuoc" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colChon" text="Chọn" prefWidth="50" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colMaLoLap" text="Mã Lô" prefWidth="120" />
                        <TableColumn fx:id="colTenThuocLap" text="Tên Thuốc" prefWidth="350" />
                        <TableColumn fx:id="colTonKhoLap" text="Tồn Kho" prefWidth="150" style="-fx-alignment: CENTER; -fx-font-weight: bold;" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>
            </VBox>
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <Label fx:id="lblDaChon" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #475569;" text="Đã chọn: 0 mặt hàng" />
                <Button text="[Bắt đầu kiểm kê]" onAction="#handleBatDauKiemKe" styleClass="btn-blue" prefHeight="45" prefWidth="180" />
            </HBox>
        </VBox>

        <VBox fx:id="viewDangDem" managed="false" visible="false" spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #1e293b;" text="ĐANG ĐẾM KHO THỰC TẾ" />
                <Label fx:id="lblMaPhieuDem" style="-fx-font-weight: bold; -fx-text-fill: #0ea5e9; -fx-font-size: 18px;" text="PKK_---" />
                <Label style="-fx-padding: 4 10; -fx-background-radius: 12; -fx-background-color: #dbeafe; -fx-text-fill: #2563eb; -fx-font-weight: bold;" text="ĐANG KIỂM KÊ" />
            </HBox>
            <VBox styleClass="panel-white" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableChiTietDem" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMaLoDem" prefWidth="100" text="Mã Lô" />
                        <TableColumn fx:id="colTenThuocDem" prefWidth="300" text="Tên Thuốc" />
                        <TableColumn fx:id="colTonSnapshotDem" prefWidth="150" style="-fx-alignment: CENTER;" text="Tồn Hiện Tại" />
                        <TableColumn fx:id="colThucTeDem" prefWidth="150" text="Số lượng Thực Tế" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
            </VBox>
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                <Button onAction="#handleImportCSV" prefHeight="45.0" prefWidth="160.0" styleClass="btn-yellow" text="📂 Import CSV" />
                <Button onAction="#handleNopPhieuKiemKe" prefHeight="45.0" prefWidth="180.0" styleClass="btn-green" text="Nộp phiếu" />
            </HBox>
        </VBox>
    </StackPane>
</VBox>
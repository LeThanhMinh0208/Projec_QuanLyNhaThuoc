<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="main-bg" stylesheets="@../../resources/css/PhanQuyen.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_PhanQuyenController">
   <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
   <children>
      <!-- HEADER -->
      <HBox alignment="CENTER_LEFT" spacing="10">
         <Label styleClass="main-title" text="PHÂN QUYỀN NGƯỜI DÙNG" />
      </HBox>

      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <!-- BÊN TRÁI: Danh sách nhân viên -->
         <VBox prefWidth="420" spacing="12" styleClass="panel-white">
            <children>
               <Label styleClass="section-title" text="DANH SÁCH NHÂN VIÊN" />
               <HBox alignment="CENTER_LEFT" styleClass="search-box">
                  <children>
                     <TextField fx:id="txtTimKiem" prefHeight="35.0" promptText="🔍  Tìm nhân viên theo tên, mã..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                  </children>
               </HBox>
               <TableView fx:id="tableNhanVien" VBox.vgrow="ALWAYS">
                  <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                  <columns>
                     <TableColumn fx:id="colMa" prefWidth="80" text="Mã NV" />
                     <TableColumn fx:id="colHoTen" prefWidth="180" text="Họ Tên" />
                     <TableColumn fx:id="colChucVu" prefWidth="100" text="Chức Vụ" />
                  </columns>
               </TableView>
            </children>
         </VBox>

         <!-- BÊN PHẢI: Cây quyền + Thông tin NV -->
         <VBox spacing="15" HBox.hgrow="ALWAYS">
            <!-- Card thông tin nhân viên đang chọn -->
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="nv-info-card">
               <children>
                  <VBox alignment="CENTER" styleClass="avatar-circle">
                     <Label text="👤" style="-fx-font-size: 28px;" />
                  </VBox>
                  <VBox spacing="3">
                     <Label fx:id="lblNhanVienDangChon" styleClass="nv-name" text="Chưa chọn nhân viên" />
                     <HBox spacing="15">
                        <Label fx:id="lblMaNV" styleClass="nv-detail" text="---" />
                        <Label text="•" style="-fx-text-fill: #94a3b8;" />
                        <Label fx:id="lblChucVu" styleClass="nv-detail" text="---" />
                     </HBox>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER_RIGHT" spacing="5">
                     <HBox spacing="8" alignment="CENTER_RIGHT">
                        <Button onAction="#handleChonTatCa" styleClass="btn-select-all" text="✓ Chọn tất cả" />
                        <Button onAction="#handleBoChonTatCa" styleClass="btn-deselect-all" text="✕ Bỏ chọn" />
                     </HBox>
                  </VBox>
               </children>
            </HBox>

            <!-- Cây quyền -->
            <VBox spacing="10" styleClass="panel-white" VBox.vgrow="ALWAYS">
               <children>
                  <Label styleClass="section-title" text="CÂY QUYỀN TRUY CẬP" />
                  <TreeView fx:id="treeQuyen" VBox.vgrow="ALWAYS" />
                  <HBox alignment="CENTER_RIGHT" spacing="10">
                     <padding><Insets top="5" /></padding>
                     <Button onAction="#handleLuuQuyen" styleClass="btn-save" text="💾  Lưu Phân Quyền" />
                  </HBox>
               </children>
            </VBox>
         </VBox>
      </HBox>
   </children>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="25.0" styleClass="main-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_DanhMucThuocController">
   
   <stylesheets>
      <URL value="@../../resources/css/TrangChu.css" />
      <URL value="@../../resources/css/DanhMucThuoc.css" />
      <URL value="@../../resources/css/BanHang.css" />
   </stylesheets>
   
   <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" spacing="20">
          <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
              <children>
                  <Label fx:id="lblTitle" styleClass="main-title" text="QUẢN LÝ DANH MỤC THUỐC" />
                  <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
              </children>
          </VBox>
       </HBox>
      
      <GridPane hgap="8" maxWidth="Infinity">
         <columnConstraints>
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.34" hgrow="ALWAYS" />
         </columnConstraints>
         <children>
            <Button fx:id="btnThem" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleThem" styleClass="top-card, card-green, btn-action" text="＋ Thêm mới" textFill="WHITE" GridPane.columnIndex="0" />

            <Button fx:id="btnSua" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleSua" styleClass="top-card, card-blue, btn-action" text="✎ Cập nhật" textFill="WHITE" GridPane.columnIndex="1" />

            <Button fx:id="btnXoa" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleXoa" styleClass="top-card, card-orange, btn-action" text="✖ Xóa" textFill="WHITE" GridPane.columnIndex="2" />
         </children>
      </GridPane>

      <HBox alignment="CENTER_RIGHT" spacing="12.0">
         <children>
            <Button fx:id="btnDoiThuoc" managed="false" minHeight="40" onAction="#handleDoiThuoc" prefHeight="40" prefWidth="180" styleClass="top-card, card-blue, btn-action" text="Đổi thuốc" textFill="WHITE" visible="false" />
         </children>
      </HBox>

      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="45.0" styleClass="search-box" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="search-icon" text="🔍" />
                  <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm theo tên, hoạt chất..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                  <Button text="Làm mới" onAction="#handleRefresh" styleClass="bh-btn-secondary" prefHeight="32"/>
               </children>
            </HBox>
         </children>
      </HBox>

     <VBox styleClass="panel-white" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="tableThuoc" prefHeight="500.0" styleClass="table-view" style="-fx-fixed-cell-size: 72;" VBox.vgrow="ALWAYS">
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colMa" prefWidth="80.0" text="Mã" />
                  <TableColumn fx:id="colHinhAnh" prefWidth="90.0" text="Ảnh" />
                  <TableColumn fx:id="colTen" prefWidth="180.0" text="Tên Thuốc" />
                  <TableColumn fx:id="colDanhMuc" prefWidth="150.0" text="Danh Mục" />
                  <TableColumn fx:id="colHoatChat" prefWidth="130.0" text="Hoạt Chất" />
                  <TableColumn fx:id="colHangSX" prefWidth="120.0" text="Hãng SX" />
                  <TableColumn fx:id="colKeDon" prefWidth="80.0" text="Kê Đơn" />
                  <TableColumn fx:id="colNuocSX" prefWidth="100.0" text="Nước SX" />
                  <TableColumn fx:id="colCongDung" prefWidth="180.0" text="Công Dụng" />
                  <TableColumn fx:id="colTrangThai" prefWidth="120.0" text="Trạng Thái" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>

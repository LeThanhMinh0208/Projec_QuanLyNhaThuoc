<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox styleClass="main-bg" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.main.GUI_DanhSachHoaDonController">

    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
        <URL value="@../../resources/css/Danhsachhoadon.css" />
    </stylesheets>

    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <VBox alignment="CENTER_LEFT" spacing="2.0" maxWidth="-Infinity">
        <children>
            <Label styleClass="main-title" text="DANH SÁCH HÓA ĐƠN" />
            <Region styleClass="xk-title-line" prefHeight="4.0" prefWidth="350.0" />
        </children>
        <padding>
            <Insets bottom="15.0" />
        </padding>
    </VBox>

    <VBox styleClass="bh-panel" spacing="12">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Từ ngày:" style="-fx-text-fill:#475569; -fx-font-weight:bold;" />
            <DatePicker fx:id="dpTuNgay" prefHeight="38.0" prefWidth="150.0" styleClass="invoice-input" />
            
            <Label text="Đến ngày:" style="-fx-text-fill:#475569; -fx-font-weight:bold;" />
            <DatePicker fx:id="dpDenNgay" prefHeight="38.0" prefWidth="150.0" styleClass="invoice-input" />
            
            <Label text="Hình thức:" style="-fx-text-fill:#475569; -fx-font-weight:bold;" />
            <ComboBox fx:id="cbHinhThuc" prefHeight="38.0" prefWidth="160.0" styleClass="invoice-input" />
            
            <Label text="Loại:" style="-fx-text-fill:#475569; -fx-font-weight:bold;" />
            <ComboBox fx:id="cbLoaiBan" prefHeight="38.0" prefWidth="160.0" styleClass="invoice-input" />
        </HBox>
        
       
        
        <HBox spacing="15" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" styleClass="invoice-search-wrapper" HBox.hgrow="ALWAYS" prefHeight="42.0">
                <children>
                    <Label style="-fx-padding: 0 0 0 15; -fx-font-size: 16px; -fx-text-fill: #0ea5e9;" text="🔍" />
                    <TextField fx:id="txtTimKiem" promptText="Nhập mã hóa đơn, tên hoặc số điện thoại khách hàng..."
                               styleClass="search-input" HBox.hgrow="ALWAYS" />
                </children>
            </HBox>
            <Button text="Tìm kiếm" onAction="#handleTimKiem"
                    styleClass="btn-pill-action, btn-search-blue" prefHeight="40" prefWidth="120" />
            <Button text="Xóa bộ lọc" onAction="#handleXoaBoLoc"
                    styleClass="btn-pill-action, btn-clear-white" prefHeight="40" prefWidth="120" />
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white" style="-fx-padding:10;">
        <TableView fx:id="tableHoaDon" VBox.vgrow="ALWAYS">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colMaHD" text="MÃ HĐ" prefWidth="90" />
                <TableColumn fx:id="colNgayLap" text="NGÀY LẬP" prefWidth="140" />
                <TableColumn fx:id="colKhachHang" text="KHÁCH HÀNG" prefWidth="150" />
                <TableColumn fx:id="colNhanVien" text="NHÂN VIÊN" prefWidth="140" />
                <TableColumn fx:id="colLoaiBan" text="LOẠI" prefWidth="100" />
                <TableColumn fx:id="colTamTinh" text="TẠM TÍNH" prefWidth="120" />
                <TableColumn fx:id="colVAT" text="VAT" prefWidth="60" />
                <TableColumn fx:id="colTongSauVAT" text="TỔNG TIỀN" prefWidth="130" />
                <TableColumn fx:id="colHinhThuc" text="THANH TOÁN" prefWidth="120" />
                <TableColumn fx:id="colHanhDong" text="THAO TÁC" prefWidth="100" />
            </columns>
        </TableView>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="30" style="-fx-padding:12 0 0 0;">
        <Label fx:id="lblTongHoaDon" text="Tổng: 0 hóa đơn" style="-fx-text-fill:#64748b; -fx-font-weight:bold;" />
        <HBox HBox.hgrow="ALWAYS" />
        <Label text="TỔNG DOANH THU:" style="-fx-text-fill:#64748b; -fx-font-weight:bold;" />
        <Label fx:id="lblTongDoanhThu" text="0 ₫" style="-fx-text-fill:#16a34a; -fx-font-size:18px; -fx-font-weight:900;" />
    </HBox>
</VBox>
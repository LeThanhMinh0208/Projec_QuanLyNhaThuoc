<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox styleClass="main-bg" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.main.GUI_DanhSachHoaDonController">

    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
    </stylesheets>

    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16" VBox.vgrow="NEVER" style="-fx-padding:0 0 16 0;">
        <Label styleClass="main-title" text="DANH SÁCH HÓA ĐƠN" />
    </HBox>

    <!-- ===== THANH FILTER ===== -->
    <VBox styleClass="bh-panel" spacing="10" VBox.vgrow="NEVER">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Từ ngày:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" prefWidth="70" />
            <DatePicker fx:id="dpTuNgay" prefWidth="150" />
            <Label text="Đến ngày:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" prefWidth="80" />
            <DatePicker fx:id="dpDenNgay" prefWidth="150" />
            <Label text="Hình thức TT:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" />
            <ComboBox fx:id="cbHinhThuc" prefWidth="160" promptText="Tất cả" />
        </HBox>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Tìm kiếm:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" prefWidth="70" />
            <HBox alignment="CENTER_LEFT" styleClass="search-box" HBox.hgrow="ALWAYS">
                <Label styleClass="search-icon" text="🔍" />
                <TextField fx:id="txtTimKiem" promptText="Mã HĐ, tên/SĐT khách hàng..."
                           styleClass="search-input" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button text="🔍 Tìm kiếm" onAction="#handleTimKiem"
                    styleClass="bh-btn-primary" prefHeight="38" prefWidth="120" />
            <Button text="✕ Xóa bộ lọc" onAction="#handleXoaBoLoc"
                    styleClass="bh-btn-secondary" prefHeight="38" prefWidth="120" />
        </HBox>
    </VBox>

    <!-- ===== BẢNG DANH SÁCH ===== -->
    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white" style="-fx-padding:0;">
        <TableView fx:id="tableHoaDon" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <placeholder>
                <Label text="Chưa có hóa đơn nào" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;" />
            </placeholder>
            <columns>
                <TableColumn fx:id="colMaHD"       text="Mã HĐ"        prefWidth="90" />
                <TableColumn fx:id="colNgayLap"    text="Ngày Lập"      prefWidth="140" />
                <TableColumn fx:id="colKhachHang"  text="Khách Hàng"    prefWidth="150" />
                <TableColumn fx:id="colNhanVien"   text="Nhân Viên"     prefWidth="140" />
                <TableColumn fx:id="colTamTinh"    text="Tạm Tính"      prefWidth="120" />
                <TableColumn fx:id="colVAT"        text="VAT"           prefWidth="60" />
                <TableColumn fx:id="colTongSauVAT" text="Tổng Sau VAT"  prefWidth="130" />
                <TableColumn fx:id="colHinhThuc"   text="Hình Thức TT"  prefWidth="130" />
                <TableColumn fx:id="colHanhDong"   text="Hành Động"     prefWidth="120" />
            </columns>
        </TableView>
    </VBox>

    <!-- ===== FOOTER ===== -->
    <HBox alignment="CENTER_LEFT" spacing="30" VBox.vgrow="NEVER"
          style="-fx-padding:12 0 0 0;">
        <Label fx:id="lblTongHoaDon" text="Tổng: 0 hóa đơn"
               style="-fx-text-fill:#64748b; -fx-font-size:13px;" />
        <HBox HBox.hgrow="ALWAYS" />
        <Label text="Tổng doanh thu:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" />
        <Label fx:id="lblTongDoanhThu" text="0 ₫"
               style="-fx-text-fill:#16a34a; -fx-font-size:16px; -fx-font-weight:bold;" />
    </HBox>
</VBox>

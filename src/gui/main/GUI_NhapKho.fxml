<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox prefHeight="850.0" spacing="20.0" styleClass="nk-main-bg" stylesheets="@../../resources/css/NhapKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_NhapKhoController">
   <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="30.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="nk-page-title" text="LẬP PHIẾU NHẬP KHO" />
                  <Region prefHeight="4.0" prefWidth="150.0" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
               </children>
            </VBox>
            
            <HBox styleClass="tab-container" alignment="CENTER_LEFT">
               <children>
                  <ToggleButton fx:id="tabTaoPhieu" selected="true" text="✨ Lập Phiếu Nhập" styleClass="tab-toggle-button">
                     <toggleGroup><ToggleGroup fx:id="tabGroup" /></toggleGroup>
                  </ToggleButton>
                  <ToggleButton fx:id="tabDanhSach" text="📋 Danh Mục Phiếu Nhập" toggleGroup="$tabGroup" styleClass="tab-toggle-button" />
               </children>
            </HBox>
         </children>
      </HBox>

      <StackPane VBox.vgrow="ALWAYS">
         <children>
            
            <HBox fx:id="viewTaoPhieu" spacing="25.0">
               <children>
                 <VBox prefWidth="350.0" spacing="15.0" styleClass="box-nhap-lieu">
                     <children>
                        <Label text="Thông Tin Phiếu Nhập" styleClass="label-header" />
                        <Region prefHeight="1.0" style="-fx-background-color: #bae6fd;" />
                        
                        <VBox spacing="15.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Mã Đơn Đặt (*):" styleClass="input-label-title" />
                                    <ComboBox fx:id="cbMaDon" prefHeight="40.0" maxWidth="Infinity" promptText="-- Chọn mã đơn --" styleClass="input-field" />
                                 </children>
                              </VBox>

                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Nhà Cung Cấp:" styleClass="input-label-title" />
                                    <TextField fx:id="txtNhaCungCap" prefHeight="40.0" editable="false" styleClass="input-field, input-field-readonly" />
                                 </children>
                              </VBox>

                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Người Giao:" styleClass="input-label-title" />
                                    <TextField fx:id="txtNguoiGiao" prefHeight="40.0" promptText="VD: Nguyễn Văn A..." styleClass="input-field" />
                                 </children>
                              </VBox>

                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Ngày Nhập:" styleClass="input-label-title" />
                                    <DatePicker fx:id="dpNgayNhap" prefHeight="40.0" maxWidth="Infinity" styleClass="input-field" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                        
                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                           <children>
                              <Label text="Ghi Chú:" styleClass="input-label-title" />
                              <TextArea fx:id="txtGhiChu" prefRowCount="4" promptText="Ghi chú thêm về lô hàng nhập..." wrapText="true" styleClass="input-field" VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
              

                  <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                     <children>
                        <VBox styleClass="nk-card" VBox.vgrow="ALWAYS">
                           <children>
                              <Label text="Chi Tiết Hàng Thực Nhận" styleClass="label-header" style="-fx-padding: 15 15 5 15;" />
                              <TableView fx:id="tableNhapKho" editable="true" styleClass="nk-table" VBox.vgrow="ALWAYS">
                                 <columns>
                                    <TableColumn fx:id="colTenThuoc" prefWidth="200.0" text="TÊN THUỐC" />
                                    <TableColumn fx:id="colDonVi" prefWidth="80.0" text="Đ.VỊ" />
                                    <TableColumn fx:id="colSLDat" prefWidth="80.0" text="SL ĐẶT" />
                                    <TableColumn fx:id="colSLNhan" prefWidth="80.0" text="SL NHẬN" />
                                    <TableColumn fx:id="colMaLo" prefWidth="100.0" text="MÃ LÔ" />
                                    <TableColumn fx:id="colNgaySX" prefWidth="120.0" text="NGÀY SX" />
                                    <TableColumn fx:id="colHanDung" prefWidth="120.0" text="HẠN DÙNG" />
                                    <TableColumn fx:id="colGiaNhap" prefWidth="120.0" text="GIÁ/ĐV" />
                                 </columns>
                                 <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                              </TableView>
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 10 0 0 0;">
                           <children>
                              <VBox alignment="CENTER_RIGHT">
                                 <children>
                                    <Label text="Tổng Tiền Cần Thanh Toán:" styleClass="input-label-title" style="-fx-font-size: 14px;" />
                                    <Label fx:id="lblTongTien" text="0 VNĐ" styleClass="text-total-price" />
                                 </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <Button onAction="#handleHuyNhapKho" prefHeight="45.0" prefWidth="120.0" styleClass="btn-cancel" text="Hủy Bỏ" />
                              <Button onAction="#handleLuuPhieuNhap" prefHeight="45.0" prefWidth="220.0" styleClass="btn-success" text="✔ XÁC NHẬN NHẬP KHO" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox fx:id="viewDanhSach" managed="false" spacing="20.0" styleClass="nk-card" visible="false">
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <Label styleClass="label-header" text="Danh Mục Các Phiếu Đã Nhập Kho" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" styleClass="nk-search-wrapper" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 16px; -fx-text-fill: #0ea5e9;" text="🔍" />
                              <TextField fx:id="txtTimKiemPhieuNhap" prefHeight="45.0" promptText="Tìm mã phiếu, nhà cung cấp..." styleClass="nk-search-field" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  
                  <TableView fx:id="tablePhieuNhap" styleClass="nk-table" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colXemChiTietPN" prefWidth="90.0" text="XEM" />
                        <TableColumn fx:id="colMaPhieuNhap" prefWidth="120.0" text="MÃ PHIẾU" />
                        <TableColumn fx:id="colNgayNhapPN" prefWidth="150.0" text="NGÀY NHẬP" />
                        <TableColumn fx:id="colNhaCungCapPN" prefWidth="300.0" text="NHÀ CUNG CẤP" />
                        <TableColumn fx:id="colNhanVienPN" prefWidth="180.0" text="NGƯỜI LẬP" />
                        <TableColumn fx:id="colTongTienPN" prefWidth="180.0" text="TỔNG TIỀN" />
                     </columns>
                     <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                  </TableView>
               </children>
            </VBox>

         </children>
      </StackPane>
   </children>
</VBox>
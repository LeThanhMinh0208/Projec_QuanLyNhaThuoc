<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="850.0" spacing="20.0" styleClass="nk-main-bg" stylesheets="@../../resources/css/NhapKho.css" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_XuLyDoiTraController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16" VBox.vgrow="NEVER" style="-fx-padding: 0 0 10 0;">
        <children>
            <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
                <children>
                    <Label styleClass="main-title" text="ĐỔI TRẢ THUỐC" />
                    <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
                </children>
            </VBox>
            <HBox alignment="CENTER_LEFT" styleClass="tab-container">
                <children>
                    <ToggleButton fx:id="tabXuLyDoiTra" selected="true" styleClass="tab-toggle-button" text="Lập phiếu đổi trả">
                        <toggleGroup>
                            <ToggleGroup fx:id="tabGroup" />
                        </toggleGroup>
                    </ToggleButton>
                    <ToggleButton fx:id="tabDanhSachPhieuDoiTra" styleClass="tab-toggle-button" text="Danh mục phiếu đổi trả" toggleGroup="$tabGroup" />
                </children>
            </HBox>
        </children>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <children>
            <VBox fx:id="viewXuLyDoiTra" spacing="14" VBox.vgrow="ALWAYS">
                <children>
                    <VBox spacing="15.0" styleClass="box-nhap-lieu" VBox.vgrow="NEVER">
                        <children>
                            <VBox spacing="10" styleClass="bh-panel" VBox.vgrow="NEVER">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label prefWidth="70" style="-fx-text-fill:#64748b; -fx-font-size:13px;" text="Từ ngày:" />
            <DatePicker fx:id="dpTuNgay" prefWidth="150" />
            <Label prefWidth="80" style="-fx-text-fill:#64748b; -fx-font-size:13px;" text="Đến ngày:" />
            <DatePicker fx:id="dpDenNgay" prefWidth="150" />
            <Label style="-fx-text-fill:#64748b; -fx-font-size:13px;" text="Hình thức TT:" />
            <ComboBox fx:id="cbHinhThuc" prefWidth="160" promptText="Tất cả" />
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label prefWidth="70" style="-fx-text-fill:#64748b; -fx-font-size:13px;" text="Tìm kiếm:" />
            <HBox alignment="CENTER_LEFT" styleClass="search-box" HBox.hgrow="ALWAYS">
                <Label styleClass="search-icon" text="🔍" />
                <TextField fx:id="txtTimKiem" promptText="Mã HĐ, tên/SĐT khách hàng..." styleClass="search-input" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button onAction="#handleTimKiem" prefHeight="38" prefWidth="120" styleClass="bh-btn-primary" text="🔍 Tìm kiếm" />
            <Button onAction="#handleXoaBoLoc" prefHeight="38" prefWidth="120" styleClass="bh-btn-secondary" text="✕ Xóa bộ lọc" />
        </HBox>
    </VBox>
                        </children>
                    </VBox>

                    <VBox styleClass="nk-card" VBox.vgrow="ALWAYS">
                        <children>
                            <TableView fx:id="tableHoaDon" styleClass="nk-table" VBox.vgrow="ALWAYS">
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                                <placeholder>
                                    <Label style="-fx-text-fill:#94a3b8; -fx-font-size:14px;" text="Chưa có hóa đơn nào" />
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="colMaHD" prefWidth="90" text="Mã HD" />
                                    <TableColumn fx:id="colNgayLap" prefWidth="140" text="Ngày lập" />
                                    <TableColumn fx:id="colKhachHang" prefWidth="150" text="Khách hàng" />
                                    <TableColumn fx:id="colNhanVien" prefWidth="140" text="Nhân viên" />
                                    <TableColumn fx:id="colTamTinh" prefWidth="120" text="Tạm tính" />
                                    <TableColumn fx:id="colVAT" prefWidth="60" text="VAT" />
                                    <TableColumn fx:id="colTongSauVAT" prefWidth="130" text="Tổng sau VAT" />
                                    <TableColumn fx:id="colHinhThuc" prefWidth="130" text="Hình thức TT" />
                                    <TableColumn fx:id="colHanhDong" prefWidth="170" text="Hành động" />
                                </columns>
                            </TableView>
                        </children>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="30" style="-fx-padding:12 0 0 0;" VBox.vgrow="NEVER">
        <Label fx:id="lblTongHoaDon" style="-fx-text-fill:#64748b; -fx-font-size:13px;" text="Tổng: 0 hóa đơn" />
        <HBox HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill:#64748b; -fx-font-size:13px;" text="Tổng doanh thu:" />
        <Label fx:id="lblTongDoanhThu" style="-fx-text-fill:#16a34a; -fx-font-size:16px; -fx-font-weight:bold;" text="0 ₫" />
    </HBox>
                </children>
            </VBox>

            <VBox fx:id="viewDanhSachPhieuDoiTra" managed="false" spacing="20.0" styleClass="nk-card" visible="false" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                            <Label styleClass="label-header" text="Danh mục các phiếu đổi trả" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox alignment="CENTER_LEFT" styleClass="nk-search-wrapper" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label style="-fx-font-size: 16px; -fx-text-fill: #0ea5e9;" text="🔍" />
                                    <TextField fx:id="txtTimKiemPhieuDoiTra" prefHeight="45.0" promptText="Mã phiếu, tên khách hàng,..." styleClass="nk-search-field" HBox.hgrow="ALWAYS" />
                                </children>
                            </HBox>
                            <Button onAction="#handleLamMoiDanhSachPhieu" prefHeight="45.0" prefWidth="120.0" styleClass="btn-cancel" text="Làm mới" />
                        </children>
                    </HBox>

                    <TableView fx:id="tablePhieuDoiTra" styleClass="nk-table" VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <placeholder>
                            <Label style="-fx-text-fill:#94a3b8; -fx-font-size:14px;" text="Chưa có phiếu đổi trả nào" />
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colMaPhieuDoiTra" prefWidth="120" text="Mã phiếu" />
                            <TableColumn fx:id="colNgayDoiTra" prefWidth="150" text="Ngày đổi trả" />
                            <TableColumn fx:id="colMaHoaDonPDT" prefWidth="110" text="Mã hóa đơn" />
                            <TableColumn fx:id="colKhachHangPDT" prefWidth="180" text="Khách hàng" />
                            <TableColumn fx:id="colNhanVienPDT" prefWidth="160" text="Nhân viên" />
                            <TableColumn fx:id="colHinhThucXuLyPDT" prefWidth="140" text="Hình thức" />
                            <TableColumn fx:id="colPhiPhatPDT" prefWidth="165" text="Phí phạt" />
                            <TableColumn fx:id="colLyDoPDT" prefWidth="140" text="Lý do" />
                            <TableColumn fx:id="colChiTietPDT" prefWidth="90" text="Chi tiết" />
                        </columns>
                    </TableView>
                </children>
            </VBox>
        </children>
    </StackPane>
</VBox>

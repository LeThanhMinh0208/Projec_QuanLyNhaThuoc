<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="850.0" spacing="20.0" styleClass="main-bg" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_XuLyDoiTraController">
    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
        <URL value="@../../resources/css/XuLyDoiTra.css" />
    </stylesheets>
    
    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <HBox alignment="CENTER_LEFT" spacing="25" style="-fx-padding: 0 0 10 0;">
        <children>
            <VBox alignment="CENTER_LEFT" spacing="2.0">
                <children>
                    <Label styleClass="main-title" text="ĐỔI TRẢ THUỐC" />
                    <Region styleClass="xk-title-line" prefHeight="4.0" prefWidth="300.0" />
                </children>
            </VBox>
            
            <HBox alignment="CENTER_LEFT" styleClass="tab-container">
                <children>
                    <ToggleButton fx:id="tabXuLyDoiTra" selected="true" styleClass="tab-toggle-button" text="Lập phiếu đổi trả">
                        <toggleGroup><ToggleGroup fx:id="tabGroup" /></toggleGroup>
                    </ToggleButton>
                    <ToggleButton fx:id="tabDanhSachPhieuDoiTra" styleClass="tab-toggle-button" text="Danh mục phiếu đổi trả" toggleGroup="$tabGroup" />
                </children>
            </HBox>
        </children>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <children>
            <VBox fx:id="viewXuLyDoiTra" spacing="15" VBox.vgrow="ALWAYS">
                <children>
                    <VBox styleClass="bh-panel" spacing="12">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Label text="Từ ngày:" style="-fx-font-weight:bold; -fx-text-fill:#475569;"/>
                                <DatePicker fx:id="dpTuNgay" prefHeight="38.0" prefWidth="150.0" styleClass="dt-input" />
                                <Label text="Đến ngày:" style="-fx-font-weight:bold; -fx-text-fill:#475569;"/>
                                <DatePicker fx:id="dpDenNgay" prefHeight="38.0" prefWidth="150.0" styleClass="dt-input" />
                                <Label text="Thanh toán:" style="-fx-font-weight:bold; -fx-text-fill:#475569;"/>
                                <ComboBox fx:id="cbHinhThuc" prefHeight="38.0" prefWidth="160.0" styleClass="dt-input" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <HBox alignment="CENTER_LEFT" styleClass="dt-search-wrapper" HBox.hgrow="ALWAYS" prefHeight="40.0">
                                    <Label style="-fx-font-size: 16px; -fx-text-fill: #0ea5e9; -fx-padding:0 0 0 10;" text="🔍" />
                                    <TextField fx:id="txtTimKiem" promptText="Mã hóa đơn, tên/SĐT khách hàng..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                                </HBox>
                                <Button onAction="#handleTimKiem" text="Tìm kiếm" styleClass="btn-pill-action, bh-btn-primary" prefHeight="40" prefWidth="120"/>
                                <Button onAction="#handleXoaBoLoc" text="Xóa bộ lọc" styleClass="btn-pill-action, bh-btn-secondary" prefHeight="40" prefWidth="120"/>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white">
                        <children>
                            <TableView fx:id="tableHoaDon" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colMaHD" text="MÃ HD" />
                                    <TableColumn fx:id="colNgayLap" text="NGÀY LẬP" />
                                    <TableColumn fx:id="colKhachHang" text="KHÁCH HÀNG" />
                                    <TableColumn fx:id="colNhanVien" text="NHÂN VIÊN" />
                                    <TableColumn fx:id="colTamTinh" text="TẠM TÍNH" />
                                    <TableColumn fx:id="colVAT" text="VAT" />
                                    <TableColumn fx:id="colTongSauVAT" text="TỔNG TIỀN" />
                                    <TableColumn fx:id="colHinhThuc" text="THANH TOÁN" />
                                    <TableColumn fx:id="colHanhDong" text="THAO TÁC" style="-fx-alignment: CENTER;" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            </TableView>
                        </children>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="30" style="-fx-padding:10 0 0 0;">
                        <Label fx:id="lblTongHoaDon" style="-fx-text-fill:#64748b; -fx-font-weight:bold;" text="Tổng: 0 hóa đơn" />
                        <HBox HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill:#64748b; -fx-font-weight:bold;" text="TỔNG DOANH THU:" />
                        <Label fx:id="lblTongDoanhThu" style="-fx-text-fill:#16a34a; -fx-font-size:18px; -fx-font-weight:900;" text="0 ₫" />
                    </HBox>
                </children>
            </VBox>

            <VBox fx:id="viewDanhSachPhieuDoiTra" managed="false" spacing="15.0" visible="false" VBox.vgrow="ALWAYS">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                            <HBox alignment="CENTER_LEFT" styleClass="dt-search-wrapper" HBox.hgrow="ALWAYS" prefHeight="42.0">
                                <children>
                                    <Label style="-fx-font-size: 16px; -fx-text-fill: #0ea5e9; -fx-padding:0 0 0 12;" text="🔍" />
                                    <TextField fx:id="txtTimKiemPhieuDoiTra" promptText="Tìm mã phiếu, tên khách hàng..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                                </children>
                            </HBox>
                            <Button onAction="#handleLamMoiDanhSachPhieu" prefHeight="40.0" prefWidth="120.0" styleClass="btn-pill-action, bh-btn-secondary" text="Làm mới" />
                        </children>
                    </HBox>

                    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white">
                        <children>
                            <TableView fx:id="tablePhieuDoiTra" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colMaPhieuDoiTra" text="MÃ PHIẾU" />
                                    <TableColumn fx:id="colNgayDoiTra" text="NGÀY LẬP" />
                                    <TableColumn fx:id="colMaHoaDonPDT" text="MÃ HÓA ĐƠN" />
                                    <TableColumn fx:id="colKhachHangPDT" text="KHÁCH HÀNG" />
                                    <TableColumn fx:id="colNhanVienPDT" text="NHÂN VIÊN" />
                                    <TableColumn fx:id="colHinhThucXuLyPDT" text="HÌNH THỨC" />
                                    <TableColumn fx:id="colPhiPhatPDT" text="PHÍ PHẠT" />
                                    <TableColumn fx:id="colLyDoPDT" text="LÝ DO" />
                                    <TableColumn fx:id="colChiTietPDT" text="CHI TIẾT" style="-fx-alignment: CENTER;" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            </TableView>
                        </children>
                    </VBox>
                </children>
            </VBox>
        </children>
    </StackPane>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="main-bg" stylesheets="@../../resources/css/NhatKyHoatDong.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_NhatKyHoatDongController">
   <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="10">
         <Label styleClass="main-title" text="NHẬT KÝ HOẠT ĐỘNG" />
      </HBox>

      <!-- THANH LỌC -->
      <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filter-bar">
         <children>
            <VBox spacing="4">
               <Label text="Nhân viên:" styleClass="filter-label" />
               <ComboBox fx:id="cboNhanVien" prefWidth="200" styleClass="filter-input" />
            </VBox>
            <VBox spacing="4">
               <Label text="Từ ngày:" styleClass="filter-label" />
               <DatePicker fx:id="dpTuNgay" prefWidth="150" styleClass="filter-input" />
            </VBox>
            <VBox spacing="4">
               <Label text="Đến ngày:" styleClass="filter-label" />
               <DatePicker fx:id="dpDenNgay" prefWidth="150" styleClass="filter-input" />
            </VBox>
            <VBox spacing="4">
               <Label text="Tìm kiếm:" styleClass="filter-label" />
               <TextField fx:id="txtTimKiem" prefWidth="250" promptText="Mô tả, hành động, mã..." styleClass="filter-input" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox spacing="4">
               <Label text=" " />
               <HBox spacing="8">
                  <Button onAction="#handleLoc" text="Lọc" styleClass="bh-btn-primary" />
                  <Button onAction="#handleLamMoi" text="Làm Mới" styleClass="bh-btn-secondary" />
               </HBox>
            </VBox>
         </children>
      </HBox>

      <!-- BẢNG NHẬT KÝ -->
      <VBox styleClass="panel-white" VBox.vgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10">
               <Label styleClass="section-title" text="DANH SÁCH NHẬT KÝ" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblTongSo" text="Tổng: 0 bản ghi" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
            </HBox>
            <TableView fx:id="tableNhatKy" VBox.vgrow="ALWAYS">
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colSTT" prefWidth="50" text="STT" />
                  <TableColumn fx:id="colThoiGian" prefWidth="160" text="Thời Gian" />
                  <TableColumn fx:id="colNhanVien" prefWidth="150" text="Nhân Viên" />
                  <TableColumn fx:id="colHanhDong" prefWidth="130" text="Hành Động" />
                  <TableColumn fx:id="colDoiTuong" prefWidth="130" text="Đối Tượng" />
                  <TableColumn fx:id="colMaDoiTuong" prefWidth="100" text="Mã" />
                  <TableColumn fx:id="colMoTa" prefWidth="300" text="Mô Tả" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>

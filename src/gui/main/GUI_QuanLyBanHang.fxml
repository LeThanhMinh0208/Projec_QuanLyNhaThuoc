<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.ImageView?>
<?import java.lang.Double?>
<?import javafx.scene.layout.Region?>

<VBox styleClass="main-bg" stylesheets="@../../resources/css/BanHang.css"
      minWidth="1024" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.main.GUI_QuanLyBanHangController">
      
    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
    </stylesheets>

    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <children>
        <!-- ===== HEADER ===== -->
        <HBox alignment="CENTER_LEFT" spacing="16" VBox.vgrow="NEVER" minHeight="-Infinity" style="-fx-padding: 0 0 10 0;">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity" minHeight="-Infinity">
                    <children>
                        <Label styleClass="main-title" text="QUẢN LÝ BÁN HÀNG" />
                        <Region prefHeight="4.0" minHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
                    </children>
                </VBox>
                <HBox alignment="CENTER_LEFT" styleClass="tab-container">
                    <children>
                        <ToggleButton fx:id="btnBanLe" selected="true" styleClass="tab-toggle-button" text="Bán Lẻ" onAction="#onTabBanLe">
                            <toggleGroup>
                                <ToggleGroup fx:id="tabGroupBanHang" />
                            </toggleGroup>
                        </ToggleButton>
                        <ToggleButton fx:id="btnDonThuoc" styleClass="tab-toggle-button" text="Bán Theo Đơn Thuốc" toggleGroup="$tabGroupBanHang" onAction="#onTabDonThuoc" />
                    </children>
                </HBox>

                <!-- VĐ4: Phân cách -->
                <Region HBox.hgrow="ALWAYS"/>
                <Separator orientation="VERTICAL" style="-fx-padding: 4 0;"/>

                <!-- VĐ4: Thông tin khách hàng (compact) — Tab Bán Lẻ -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Khách hàng:" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtSdtKhachLe" promptText="SĐT khách hàng..."
                               prefWidth="140" prefHeight="32"
                               styleClass="bh-input"
                               style="-fx-font-size: 12px;"/>
                    <Button onAction="#handleTimKhachLe" text="Tìm"
                            styleClass="bh-btn-primary" prefHeight="32" prefWidth="50"
                            style="-fx-font-size: 11px; -fx-padding: 4 8;"/>
                    <Label fx:id="lblTenKhachLe" text="Khách lẻ (vãng lai)"
                           style="-fx-font-style: italic; -fx-text-fill: #666; -fx-font-size: 12px;"
                           maxWidth="200"/>
                    <Button fx:id="btnXoaKH" text="✕" onAction="#onXoaKhachHang"
                            style="-fx-background-color: transparent; -fx-text-fill: #999; -fx-font-size: 11px; -fx-cursor: hand;"
                            visible="false"/>
                </HBox>
            </children>
        </HBox>

        <!-- ===== TAB PANE ===== -->
        <TabPane fx:id="tabPaneBanHang" styleClass="bh-tab-pane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>

                <!-- ══════════════════════════════════════════════
                     TAB 1: BÁN LẺ
                     ══════════════════════════════════════════════ -->
                <!-- TAB 1: BÁN LẺ -->
                <Tab>
                    <HBox spacing="16" VBox.vgrow="ALWAYS" fillHeight="true">
                        <padding><Insets top="16" /></padding>

                        <!-- ── CỘT TRÁI: CHỌN THUỐC (60%) ── -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                            <!-- Tìm kiếm -->
                            <HBox alignment="CENTER_LEFT" styleClass="search-box" prefHeight="46">
                                <children>
                                    <Label styleClass="search-icon" text="🔍" />
                                    <TextField fx:id="txtTimKiemThuocLe" prefHeight="42"
                                               promptText="Tìm theo mã, tên, triệu chứng, công dụng..."
                                               styleClass="search-input" HBox.hgrow="ALWAYS" />
                                    <Button text="Làm mới" onAction="#handleLamMoiLe"
                                            styleClass="bh-btn-secondary" prefHeight="32" style="-fx-margin: 0 5 0 0;"/>
                                </children>
                            </HBox>

                            <!-- Bảng danh sách thuốc -->
                            <VBox styleClass="bh-panel" VBox.vgrow="ALWAYS" spacing="8">
                                <children>
                                    <TableView fx:id="tblThuocLe" styleClass="table-view" style="-fx-fixed-cell-size: 72;" VBox.vgrow="ALWAYS">
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        <placeholder>
                                            <Label text="Không có thuốc nào phù hợp" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
                                        </placeholder>
                                        <columns>
                                            <TableColumn fx:id="colThuocMa" text="Mã thuốc" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="colThuocAnh" text="Ảnh" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="colThuocTen" text="Tên thuốc" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="colThuocTrieuChung" text="Triệu chứng / Công dụng" style="-fx-alignment: CENTER-LEFT;" />
                                            <TableColumn fx:id="colThuocKeDon" text="Kê đơn" style="-fx-alignment: CENTER;" />
                                        </columns>
                                    </TableView>

                                    <Button fx:id="btnThemVaoGioLe" onAction="#handleThemVaoGioLe"
                                            maxWidth="Infinity" prefHeight="42"
                                            styleClass="bh-btn-primary"
                                            text="➕  Thêm thuốc đã chọn vào giỏ hàng" />
                                </children>
                            </VBox>
                        </VBox>

                        <!-- ── CỘT PHẢI: GIỎ HÀNG + THANH TOÁN (40%) ── -->
                        <!-- VĐ4: Bỏ ScrollPane, dùng VBox với VBox.vgrow để nút thanh toán luôn visible -->
                        <VBox spacing="12" prefWidth="480" minWidth="460" style="-fx-padding: 0 16 0 0;">
                            <!-- Giỏ hàng — chiếm toàn bộ chiều cao còn lại -->
                            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="bh-cart-wrapper">
                                <children>
                                    <HBox alignment="CENTER_LEFT" styleClass="bh-cart-title-bar" spacing="8">
                                        <children>
                                            <Label text="🛒  GIỎ HÀNG" styleClass="bh-cart-title-label"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button onAction="#handleHuyGioLe" text="🗑 Xóa giỏ"
                                                    style="-fx-background-color: #f44336; -fx-text-fill: white;
                                                           -fx-background-radius: 5; -fx-padding: 4 10;
                                                           -fx-font-size: 11px; -fx-cursor: hand;"
                                                    prefHeight="28"/>
                                        </children>
                                    </HBox>
                                    <TableView fx:id="tblGioHangLe" styleClass="table-view"
                                               VBox.vgrow="ALWAYS" minHeight="140">
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        <placeholder>
                                            <Label text="Giỏ trống — chọn thuốc để thêm vào" style="-fx-text-fill:#334155; -fx-font-size:13px;"/>
                                        </placeholder>
                                        <columns>
                                            <TableColumn fx:id="colCartTenThuoc" text="Tên thuốc" prefWidth="160" minWidth="130" />
                                            <TableColumn fx:id="colCartDonVi" text="Đơn vị" prefWidth="58" minWidth="52" maxWidth="65" />
                                            <TableColumn fx:id="colCartDonGia" text="Đơn giá" prefWidth="78" minWidth="70" maxWidth="90" />
                                            <TableColumn fx:id="colCartSoLuong" text="SL" prefWidth="42" minWidth="38" maxWidth="50" />
                                            <TableColumn fx:id="colCartThanhTien" text="Thành tiền" prefWidth="88" minWidth="80" maxWidth="100" />
                                            <TableColumn fx:id="colCartXoa" text="" prefWidth="40" minWidth="40" maxWidth="40" />
                                        </columns>
                                    </TableView>
                                </children>
                            </VBox>

                            <!-- Thanh toán — luôn ở dưới cùng, không bị khuất -->
                            <VBox styleClass="bh-panel" spacing="12">
                                <children>
                                    <Label styleClass="bh-section-title" text="THANH TOÁN" />
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <children>
                                            <Label text="Hình thức:" styleClass="bh-label-key"
                                                   style="-fx-text-fill: #64748b;" prefWidth="90"/>
                                            <ComboBox fx:id="cbHinhThucThanhToanLe" prefHeight="36"
                                                      styleClass="bh-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        </children>
                                    </HBox>
                                    <Separator style="-fx-opacity: 0.5;" />
                                    <GridPane hgap="8" vgap="6">
                                        <columnConstraints>
                                            <ColumnConstraints minWidth="110" />
                                            <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT" />
                                        </columnConstraints>
                                        <children>
                                            <Label text="Tạm tính:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" GridPane.rowIndex="0" />
                                            <Label fx:id="lblTongTienLe" text="0 ₫" style="-fx-text-fill:#1e293b; -fx-font-size:14px; -fx-font-weight:bold;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                            <Label text="VAT (8%):" style="-fx-text-fill:#94a3b8; -fx-font-size:13px;" GridPane.rowIndex="1"/>
                                            <Label fx:id="lblVatLe" text="0 ₫" style="-fx-text-fill:#94a3b8; -fx-font-size:13px;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        </children>
                                    </GridPane>
                                    <Separator />
                                    <HBox alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="TỔNG THANH TOÁN" style="-fx-font-size:13px; -fx-font-weight:900; -fx-text-fill:#64748b;" HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="lblThanhTienLe" text=" 0 ₫" styleClass="bh-money-total" />
                                        </children>
                                    </HBox>
                                    <Button fx:id="btnThanhToanLe" onAction="#handleThanhToanLe"
                                            maxWidth="Infinity" prefHeight="50"
                                            styleClass="bh-btn-success"
                                            text="💳  THANH TOÁN" />
                                </children>
                            </VBox>
                        </VBox>
                    </HBox>
                </Tab>

                <!-- ══════════════════════════════════════════════
                     TAB 2: BÁN THEO ĐƠN
                     ══════════════════════════════════════════════ -->
                <!-- TAB 2: BÁN THEO ĐƠN -->
                <Tab>
                    <HBox spacing="16" VBox.vgrow="ALWAYS" fillHeight="true">
                        <padding><Insets top="16" /></padding>

                        <!-- ── CỘT TRÁI: CHỌN THUỐC (giống tab Bán lẻ) ── -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                            <!-- Tìm kiếm -->
                            <HBox alignment="CENTER_LEFT" styleClass="search-box" prefHeight="46">
                                <children>
                                    <Label styleClass="search-icon" text="🔍" />
                                    <TextField fx:id="txtTimKiemThuocDon" prefHeight="42"
                                               promptText="Tìm theo mã, tên, triệu chứng, công dụng..."
                                               styleClass="search-input" HBox.hgrow="ALWAYS" />
                                    <Button text="Làm mới" onAction="#handleLamMoiDon"
                                            styleClass="bh-btn-secondary" prefHeight="32" style="-fx-margin: 0 5 0 0;"/>
                                </children>
                            </HBox>

                            <!-- Bảng danh sách thuốc -->
                            <VBox styleClass="bh-panel" VBox.vgrow="ALWAYS" spacing="8">
                                <children>
                                    <TableView fx:id="tblThuocDon" styleClass="table-view" style="-fx-fixed-cell-size: 72;" VBox.vgrow="ALWAYS">
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        <placeholder>
                                            <Label text="Không có thuốc nào phù hợp" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
                                        </placeholder>
                                        <columns>
                                            <TableColumn fx:id="colThuocDonMa" text="Mã thuốc" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="colThuocDonAnh" text="Ảnh" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="colThuocDonTen" text="Tên thuốc" style="-fx-alignment: CENTER;" />
                                            <TableColumn fx:id="colThuocDonTrieuChung" text="Triệu chứng / Công dụng" style="-fx-alignment: CENTER-LEFT;" />
                                            <TableColumn fx:id="colThuocDonKeDon" text="Kê đơn" style="-fx-alignment: CENTER;" />
                                        </columns>
                                    </TableView>

                                    <Button fx:id="btnThemVaoGioDon" onAction="#handleThemVaoGioDon"
                                            maxWidth="Infinity" prefHeight="42"
                                            styleClass="bh-btn-primary"
                                            text="➕  Thêm thuốc đã chọn vào giỏ hàng" />
                                </children>
                            </VBox>
                        </VBox>

                        <!-- ── CỘT PHẢI: CARD ĐƠN THUỐC + GIỎ HÀNG + THANH TOÁN ── -->
                        <VBox spacing="12" prefWidth="480" minWidth="460" style="-fx-padding: 0 16 0 0;">

                            <!-- Card đơn thuốc — VBox chiều dọc -->
                            <VBox style="-fx-background-color: #EEF5FF;
                                         -fx-border-color: #BBDEFB; -fx-border-width: 1;
                                         -fx-border-radius: 6; -fx-background-radius: 6;
                                         -fx-padding: 8 12 6 12; -fx-spacing: 4;">
                                <!-- Hàng tiêu đề + nút -->
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Đơn thuốc:"
                                           style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnThemDon" text="+ Thêm đơn" onAction="#onThemDonThuoc"
                                            minWidth="90" prefWidth="90"
                                            style="-fx-background-color: #2196F3; -fx-text-fill: white;
                                                   -fx-background-radius: 6; -fx-padding: 5 12;
                                                   -fx-font-size: 12px; -fx-cursor: hand;"/>
                                    <Button fx:id="btnXemSuaDon" text="Xem / Sửa" onAction="#onXemSuaDonThuoc"
                                            minWidth="90" prefWidth="90"
                                            style="-fx-background-color: #FF9800; -fx-text-fill: white;
                                                   -fx-background-radius: 6; -fx-padding: 5 12;
                                                   -fx-font-size: 12px; -fx-cursor: hand;" visible="false"/>
                                    <Button fx:id="btnDatLaiDon" text="Đặt lại" onAction="#onDatLaiDonThuoc"
                                            minWidth="75" prefWidth="75"
                                            style="-fx-background-color: #9E9E9E; -fx-text-fill: white;
                                                   -fx-background-radius: 6; -fx-padding: 5 12;
                                                   -fx-font-size: 12px; -fx-cursor: hand;" visible="false"/>
                                </HBox>
                                <!-- Nội dung đơn thuốc (ẩn + unmanaged khi chưa có đơn) -->
                                <VBox fx:id="paneThongTinDon" visible="false" managed="false"
                                      style="-fx-padding: 4 0 0 0;">
                                    <Label fx:id="lblTrangThaiDon"
                                           text=""
                                           wrapText="true"
                                           style="-fx-text-fill: #444; -fx-font-size: 11px;
                                                  -fx-line-spacing: 2;"/>
                                </VBox>
                            </VBox>

                            <!-- Giỏ hàng theo đơn -->
                            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="bh-cart-wrapper">
                                <children>
                                    <HBox alignment="CENTER_LEFT" styleClass="bh-cart-title-bar" spacing="8">
                                        <children>
                                            <Label text="📋  GIỎ HÀNG (THEO ĐƠN)" styleClass="bh-cart-title-label"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button onAction="#handleHuyGioDon" text="🗑 Xóa giỏ"
                                                    style="-fx-background-color: #f44336; -fx-text-fill: white;
                                                           -fx-background-radius: 5; -fx-padding: 4 10;
                                                           -fx-font-size: 11px; -fx-cursor: hand;"
                                                    prefHeight="28"/>
                                        </children>
                                    </HBox>
                                    <TableView fx:id="tblGioHangDon" styleClass="table-view"
                                               VBox.vgrow="ALWAYS" minHeight="120">
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        <placeholder>
                                            <Label text="Giỏ trống — chọn thuốc để thêm vào" style="-fx-text-fill:#334155; -fx-font-size:13px;"/>
                                        </placeholder>
                                        <columns>
                                            <TableColumn fx:id="colCartDonTenThuoc" text="Tên thuốc" prefWidth="160" minWidth="130" />
                                            <TableColumn fx:id="colCartDonDonVi" text="Đơn vị" prefWidth="58" minWidth="52" maxWidth="65" />
                                            <TableColumn fx:id="colCartDonDonGia" text="Đơn giá" prefWidth="78" minWidth="70" maxWidth="90" />
                                            <TableColumn fx:id="colCartDonSoLuong" text="SL" prefWidth="42" minWidth="38" maxWidth="50" />
                                            <TableColumn fx:id="colCartDonThanhTien" text="Thành tiền" prefWidth="88" minWidth="80" maxWidth="100" />
                                            <TableColumn fx:id="colCartDonXoa" text="" prefWidth="40" minWidth="40" maxWidth="40" />
                                        </columns>
                                    </TableView>
                                </children>
                            </VBox>

                            <!-- Thanh toán — luôn ở dưới cùng -->
                            <VBox styleClass="bh-panel" spacing="12">
                                <children>
                                    <Label styleClass="bh-section-title" text="THANH TOÁN" />
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <children>
                                            <Label text="Hình thức:" style="-fx-text-fill: #64748b; -fx-font-size:13px;" prefWidth="90"/>
                                            <ComboBox fx:id="cbHinhThucThanhToanDon" prefHeight="36"
                                                      styleClass="bh-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        </children>
                                    </HBox>
                                    <Separator style="-fx-opacity: 0.5;" />
                                    <GridPane hgap="8" vgap="6">
                                        <columnConstraints>
                                            <ColumnConstraints minWidth="110" />
                                            <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT" />
                                        </columnConstraints>
                                        <children>
                                            <Label text="Tạm tính:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" GridPane.rowIndex="0" />
                                            <Label fx:id="lblTongTienDon" text="0 ₫" style="-fx-text-fill:#1e293b; -fx-font-size:14px; -fx-font-weight:bold;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                            <Label text="VAT (8%):" style="-fx-text-fill:#94a3b8; -fx-font-size:13px;" GridPane.rowIndex="1"/>
                                            <Label fx:id="lblVatDon" text="0 ₫" style="-fx-text-fill:#94a3b8; -fx-font-size:13px;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        </children>
                                    </GridPane>
                                    <Separator />
                                    <HBox alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="TỔNG THANH TOÁN" style="-fx-font-size:13px; -fx-font-weight:900; -fx-text-fill:#64748b;" HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="lblThanhTienDon" text=" 0 ₫" styleClass="bh-money-total" />
                                        </children>
                                    </HBox>
                                    <Button fx:id="btnThanhToanDon" onAction="#handleThanhToanDon"
                                            maxWidth="Infinity" prefHeight="50"
                                            styleClass="bh-btn-success"
                                            text="💳  THANH TOÁN THEO ĐƠN" />
                                </children>
                            </VBox>
                        </VBox>
                    </HBox>
                </Tab>

            </tabs>
        </TabPane>
    </children>
</VBox>

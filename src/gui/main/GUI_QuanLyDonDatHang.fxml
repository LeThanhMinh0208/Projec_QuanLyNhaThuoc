<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.Region?>

<VBox prefHeight="850.0" prefWidth="1200.0" spacing="25.0" styleClass="dmk-main-bg" stylesheets="@../../resources/css/QuanLyDonDatHang.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_QuanLyDonDatHangController">
   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>
   <children>
      <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
          <children>
              <Label styleClass="main-title" text="QUẢN LÝ ĐƠN ĐẶT HÀNG" />
              <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
          </children>
      </VBox>
      
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleLamMoi" prefHeight="45.0" prefWidth="120.0" styleClass="btn-refresh" text="↻ Làm Mới" />
            <Button mnemonicParsing="false" onAction="#handleTaoDonMoi" prefHeight="45.0" prefWidth="220.0" styleClass="btn-primary" text="+ Tạo Đơn Đặt Hàng Mới" />
            
            <Region prefWidth="20.0" />
            
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 25px; -fx-border-color: #e2e8f0; -fx-border-radius: 25px; -fx-padding: 0 15 0 15;" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-size: 16px; -fx-text-fill: #0ea5e9;" text="🔍" />
                  <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm mã đơn, nhà cung cấp..." style="-fx-background-color: transparent; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </HBox>

      <VBox styleClass="dmk-card" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="tableDonDat" styleClass="dmk-table" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colChiTiet" prefWidth="90.0" text="XEM" />
                <TableColumn fx:id="colMaDon" prefWidth="120.0" text="MÃ ĐƠN" />
                <TableColumn fx:id="colNhaCungCap" prefWidth="300.0" text="NHÀ CUNG CẤP" />
                <TableColumn fx:id="colNgayLap" prefWidth="140.0" text="NGÀY ĐẶT" />
                <TableColumn fx:id="colTrangThaiHang" prefWidth="180.0" text="TÌNH TRẠNG GIAO" />
                <TableColumn fx:id="colThaoTac" prefWidth="160.0" text="HÀNH ĐỘNG" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
   </children>
</VBox>
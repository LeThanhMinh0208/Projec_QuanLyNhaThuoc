<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="22.0" styleClass="main-bg dvqd-page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_DonViQuyDoiController">
    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
        <URL value="@../../resources/css/DonViQuyDoi.css" />
    </stylesheets>

    <padding>
        <Insets bottom="28.0" left="36.0" right="36.0" top="26.0" />
    </padding>

    <children>
        <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity" minHeight="-Infinity">
            <children>
                <Label styleClass="main-title" text="DANH SÁCH QUY ĐỔI ĐƠN VỊ THUỐC" />
                <Region prefHeight="4.0" minHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
            </children>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="dvqd-search-card">
            <padding>
                <Insets bottom="12.0" left="14.0" right="14.0" top="12.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="46.0" styleClass="search-box" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="search-icon" text="&#128269;" />
                        <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm kiếm theo mã thuốc, tên thuốc, đơn vị..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets left="14.0" right="14.0" />
                    </padding>
                </HBox>
            </children>
        </HBox>

        <VBox styleClass="panel-white dvqd-content-card" VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="tableQuyDoi" prefHeight="620.0" styleClass="table-view dvqd-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colStt" prefWidth="68.0" text="STT" />
                        <TableColumn fx:id="colMaThuoc" prefWidth="118.0" text="Mã Thuốc" />
                        <TableColumn fx:id="colTenThuoc" prefWidth="260.0" text="Tên Thuốc" />
                        <TableColumn fx:id="colDonViBac1" prefWidth="145.0" text="Đơn Vị 1" />
                        <TableColumn fx:id="colDonViBac2" prefWidth="145.0" text="Đơn Vị 2" />
                        <TableColumn fx:id="colDonViBac3" prefWidth="145.0" text="Đơn Vị 3" />
                        <TableColumn fx:id="colThaoTac" prefWidth="130.0" text="Thao Tác" />
                    </columns>
                </TableView>
            </children>
            <padding>
                <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
            </padding>
        </VBox>
    </children>
</VBox>

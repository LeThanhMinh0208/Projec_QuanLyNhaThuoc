<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="850.0" prefWidth="1200.0" spacing="20.0" styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.main.GUI_LichSuGiaoDichController">

    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
        <URL value="@../../resources/css/LichSuGiaoDich.css" />
    </stylesheets>

    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity" style="-fx-padding: 0 0 10 0;">
        <children>
            <Label styleClass="main-title" text="LỊCH SỬ GIAO DỊCH KHÁCH HÀNG" />
            <Region styleClass="xk-title-line" />
        </children>
    </VBox>

    <VBox styleClass="bh-panel" spacing="12" VBox.vgrow="NEVER">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Từ ngày:" style="-fx-text-fill:#475569; -fx-font-weight:bold;" />
            <DatePicker fx:id="dpTuNgay" prefHeight="38.0" prefWidth="150" styleClass="ls-input" />
            
            <Label text="Đến ngày:" style="-fx-text-fill:#475569; -fx-font-weight:bold;" />
            <DatePicker fx:id="dpDenNgay" prefHeight="38.0" prefWidth="150" styleClass="ls-input" />
            
            <Label text="Hình thức TT:" style="-fx-text-fill:#475569; -fx-font-weight:bold;" />
            <ComboBox fx:id="cbHinhThuc" prefHeight="38.0" prefWidth="160" styleClass="ls-input" onAction="#handleLoc" />
        </HBox>
        
        <HBox spacing="15" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" styleClass="ls-search-wrapper" HBox.hgrow="ALWAYS" prefHeight="40.0">
                <Label style="-fx-padding: 0 0 0 10; -fx-font-size: 16px; -fx-text-fill:#0ea5e9;" text="🔍" />
                <TextField fx:id="txtTimKiem" promptText="Mã HĐ, Tên hoặc SĐT khách hàng..."
                           styleClass="search-input" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button text="Tìm kiếm" onAction="#handleLoc"
                    styleClass="btn-pill-action, btn-search-blue" prefHeight="40" prefWidth="120" />
            <Button text="Xóa bộ lọc" onAction="#handleXoaLoc"
                    styleClass="btn-pill-action, btn-clear-white" prefHeight="40" prefWidth="120" />
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="panel-white" style="-fx-padding:10;">
        <TableView fx:id="tableGiaoDich" VBox.vgrow="ALWAYS">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <placeholder><Label text="Chưa có hóa đơn nào" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;" /></placeholder>
            <columns>
                <TableColumn fx:id="colMaHD"      text="MÃ HĐ"          prefWidth="90"/>
                <TableColumn fx:id="colNgayLap"   text="NGÀY LẬP"       prefWidth="140"/>
                <TableColumn fx:id="colKhachHang" text="KHÁCH HÀNG"     prefWidth="180"/>
                <TableColumn fx:id="colSdt"       text="SĐT"            prefWidth="120"/>
                <TableColumn fx:id="colTamTinh"   text="TẠM TÍNH"       prefWidth="110"/>
                <TableColumn fx:id="colVAT"       text="VAT"            prefWidth="60"/>
                <TableColumn fx:id="colTongTT"    text="TỔNG TT"        prefWidth="130"/>
                <TableColumn fx:id="colHinhThuc"  text="THANH TOÁN"     prefWidth="130"/>
                <TableColumn fx:id="colHanhDong"  text="THAO TÁC"       prefWidth="110" style="-fx-alignment: CENTER;" />
            </columns>
        </TableView>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="30" VBox.vgrow="NEVER" style="-fx-padding:10 0 0 0;">
        <Label fx:id="lblTongGiaoDich" text="Tổng: 0 giao dịch" style="-fx-text-fill:#64748b; -fx-font-weight:bold;" />
        <HBox HBox.hgrow="ALWAYS" />
        <Label text="TỔNG DOANH THU:" style="-fx-text-fill:#64748b; -fx-font-weight:bold;" />
        <Label fx:id="lblTongDoanhThu" text="0 ₫" style="-fx-text-fill:#16a34a; -fx-font-size:18px; -fx-font-weight:900;" />
    </HBox>
</VBox>
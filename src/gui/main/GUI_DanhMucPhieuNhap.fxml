<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="850.0" prefWidth="1300.0" spacing="20.0" styleClass="dmk-main-bg" stylesheets="@../../resources/css/NhapKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_DanhMucPhieuNhapController">
   <padding>
      <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
   </padding>

   <VBox spacing="15.0">
      <Label styleClass="nk-page-title" text="QUẢN LÝ PHIẾU NHẬP KHO" />
      <HBox spacing="10.0">
         <Button onAction="#handleChuyenTrangLapPhieu" styleClass="nk-tab-btn" text="➕ Lập Phiếu Nhập" />
         <Button styleClass="nk-tab-btn, nk-tab-active" text="📋 Danh Mục Phiếu Nhập" />
      </HBox>
   </VBox>

   <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="nk-card" style="-fx-padding: 15;">
      <VBox spacing="5.0">
         <Label styleClass="nk-label" text="Từ ngày:" />
         <DatePicker fx:id="dpTuNgay" prefWidth="180.0" styleClass="nk-input" />
      </VBox>
      <VBox spacing="5.0">
         <Label styleClass="nk-label" text="Đến ngày:" />
         <DatePicker fx:id="dpDenNgay" prefWidth="180.0" styleClass="nk-input" />
      </VBox>
      <VBox spacing="5.0" HBox.hgrow="ALWAYS">
         <Label styleClass="nk-label" text="Tìm kiếm nhanh:" />
         <TextField fx:id="txtTimKiem" promptText="Nhập mã phiếu, tên nhà cung cấp..." styleClass="nk-input" />
      </VBox>
      <Button onAction="#handleLamMoi" prefHeight="45.0" styleClass="nk-btn-huy" text="🔄 Làm mới" />
   </HBox>

   <VBox styleClass="nk-card" VBox.vgrow="ALWAYS">
      <Label styleClass="nk-card-title" text="Lịch Sử Nhập Kho" />
      <TableView fx:id="tablePhieuNhap" styleClass="nk-table" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colMaPhieu" prefWidth="120.0" text="Mã Phiếu" />
          <TableColumn fx:id="colNgayNhap" prefWidth="150.0" text="Ngày Nhập" />
          <TableColumn fx:id="colNhaCungCap" prefWidth="250.0" text="Nhà Cung Cấp" />
          <TableColumn fx:id="colNhanVien" prefWidth="180.0" text="Người Lập" />
          <TableColumn fx:id="colTongTien" prefWidth="180.0" text="Tổng Tiền Nhập" />
          <TableColumn fx:id="colGhiChu" prefWidth="250.0" text="Ghi Chú" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      
      <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 15 0 0 0;">
         <Button onAction="#handleXemChiTiet" prefHeight="45.0" prefWidth="180.0" styleClass="nk-btn-xacnhan" style="-fx-background-color: #3b82f6;" text="🔍 Xem Chi Tiết" />
         <Button onAction="#handleInPhieu" prefHeight="45.0" prefWidth="150.0" styleClass="nk-btn-xacnhan" text="🖨️ In Phiếu" />
      </HBox>
   </VBox>
</VBox>
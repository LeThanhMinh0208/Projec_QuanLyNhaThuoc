<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>

<VBox styleClass="main-bg" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_ChiTietDoiTraController">
    <stylesheets>
        <URL value="@../../resources/css/TrangChu.css" />
        <URL value="@../../resources/css/BanHang.css" />
    </stylesheets>

    <padding><Insets bottom="20.0" left="30.0" right="30.0" top="20.0" /></padding>

    <HBox alignment="CENTER_LEFT" spacing="16" VBox.vgrow="NEVER" style="-fx-padding:0 0 10 0;">
        <Button text="Quay lại" onAction="#handleQuayLai" styleClass="bh-btn-secondary" prefHeight="38" prefWidth="110" />
        <Label styleClass="main-title" text="CHI TIẾT ĐỔI TRẢ" />
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color:transparent; -fx-background:transparent;">
        <content>
            <VBox prefWidth="1180" spacing="16" style="-fx-padding: 0 0 10 0;">
                <VBox styleClass="bh-panel" spacing="10">
                    <Label text="THÔNG TIN HÓA ĐƠN ĐỔI TRẢ" styleClass="bh-section-title" />
                    <GridPane hgap="20" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="130" />
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints prefWidth="130" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        <Label text="Mã hóa đơn:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <Label fx:id="lblMaHD" style="-fx-font-weight:bold; -fx-text-fill:#0f172a;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label text="Ngày lập:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                        <Label fx:id="lblNgayLap" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                        <Label text="Khách hàng:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <Label fx:id="lblKhachHang" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <Label text="Nhân viên:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                        <Label fx:id="lblNhanVien" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="1" GridPane.columnIndex="3" />

                        <Label text="Tổng thanh toán:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <Label fx:id="lblTongHoaDon" style="-fx-text-fill:#0f172a; -fx-font-weight:bold;" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                        <Label text="Hình thức TT:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="2" GridPane.columnIndex="2" />
                        <Label fx:id="lblHinhThuc" style="-fx-text-fill:#0f172a;" GridPane.rowIndex="2" GridPane.columnIndex="3" />
                    </GridPane>
                </VBox>

                <VBox styleClass="bh-panel" spacing="8">
                    <Label text="CHI TIẾT HÓA ĐƠN / ĐỔI TRẢ" styleClass="bh-section-title" />
                    <TableView fx:id="tableCoTheDoiTra" prefHeight="260" style="-fx-text-background-color:#0f172a; -fx-control-inner-background:white; -fx-table-cell-border-color:#e2e8f0;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        <placeholder>
                            <Label text="Không tìm thấy chi tiết hóa đơn" style="-fx-text-fill:#64748b; -fx-font-size:14px;" />
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colHangTenThuoc" text="Tên thuốc" prefWidth="220" />
                            <TableColumn fx:id="colHangDonVi" text="Đơn vị" prefWidth="90" />
                            <TableColumn fx:id="colHangLo" text="Lô thuốc" prefWidth="110" />
                            <TableColumn fx:id="colHangHSD" text="HSD" prefWidth="110" />
                            <TableColumn fx:id="colHangDaMua" text="Đã mua" prefWidth="80" />
                            <TableColumn fx:id="colHangDaTra" text="Đã trả" prefWidth="80" />
                            <TableColumn fx:id="colHangConLai" text="Còn lại" prefWidth="80" />
                            <TableColumn fx:id="colHangDonGia" text="Đơn giá" prefWidth="110" />
                            <TableColumn fx:id="colHangTrangThai" text="Trạng thái" prefWidth="150" />
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="bh-panel" spacing="12">
                    <Label text="LẬP PHIẾU ĐỔI TRẢ" styleClass="bh-section-title" />
                    <GridPane hgap="16" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="120" />
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints prefWidth="120" />
                            <ColumnConstraints prefWidth="180" />
                        </columnConstraints>
                        <Label text="Hình thức xử lý:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <ComboBox fx:id="cbHinhThucXuLy" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Lý do:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <StackPane GridPane.rowIndex="1" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                             <ComboBox fx:id="cbLyDo" prefWidth="220" />
                             <TextField fx:id="txtLyDo" prefWidth="220" promptText="Nhập lý do đổi sản phẩm" visible="false" managed="false" />
                        </StackPane>
                        
                        <Label text="Số lượng trả:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="3">
                            <Spinner fx:id="spSoLuongTra" editable="true" prefWidth="84" prefHeight="44" />
                        </HBox>

                        <Label text="Thuốc đổi:" style="-fx-text-fill:#64748b;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <HBox alignment="CENTER_LEFT" spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="2">
                            <Button text="Chọn thuốc đổi" onAction="#handleChonThuocDoi" styleClass="bh-btn-secondary" prefHeight="32" />
                            <Button text="Bỏ chọn" onAction="#handleBoThuocDoi" styleClass="bh-btn-secondary" prefHeight="32" />
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="3">
                            <Button text="Thêm vào phiếu" onAction="#handleThemChiTiet" styleClass="bh-btn-secondary" prefHeight="36" />
                        </HBox>
                    </GridPane>
                </VBox>

                <!-- Bảng thuốc nhận đổi -->
                <VBox styleClass="bh-panel" spacing="8">
                    <Label text="THUỐC NHẬN ĐỔI (cho khách)" styleClass="bh-section-title" />
                    <TableView fx:id="tableThuocNhan" prefHeight="160" style="-fx-text-background-color:#0f172a; -fx-control-inner-background:white; -fx-table-cell-border-color:#e2e8f0;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        <placeholder>
                            <Label text="Chưa chọn thuốc đổi cho khách" style="-fx-text-fill:#64748b; -fx-font-size:14px;" />
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colNhanTenThuoc" text="Tên thuốc" prefWidth="220" />
                            <TableColumn fx:id="colNhanDonVi" text="Đơn vị" prefWidth="90" />
                            <TableColumn fx:id="colNhanSoLuong" text="Số lượng" prefWidth="80" />
                            <TableColumn fx:id="colNhanDonGia" text="Đơn giá" prefWidth="110" />
                            <TableColumn fx:id="colNhanThanhTien" text="Thành tiền" prefWidth="120" />
                            <TableColumn fx:id="colNhanXoa" text="Xóa" prefWidth="80" />
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="bh-panel" spacing="8">
                    <Label text="CHI TIẾT PHIẾU ĐỔI TRẢ" styleClass="bh-section-title" />
                    <TableView fx:id="tableChiTietDoiTra" prefHeight="220" style="-fx-text-background-color:#0f172a; -fx-control-inner-background:white; -fx-table-cell-border-color:#e2e8f0;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        <placeholder>
                            <Label text="Chưa có chi tiết đổi trả nào" style="-fx-text-fill:#64748b; -fx-font-size:14px;" />
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colCTTenThuoc" text="Tên thuốc" prefWidth="220" />
                            <TableColumn fx:id="colCTDonVi" text="Đơn vị" prefWidth="90" />
                            <TableColumn fx:id="colCTLo" text="Lô thuốc" prefWidth="110" />
                            <TableColumn fx:id="colCTSoLuong" text="Số lượng trả" prefWidth="90" />
                            <TableColumn fx:id="colCTThanhTien" text="Tiền hoàn" prefWidth="120" />
                            <TableColumn fx:id="colCTHanhDong" text="Hành động" prefWidth="100" />
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="bh-panel" spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Tổng số mặt hàng:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" />
                        <Label fx:id="lblTongDong" style="-fx-text-fill:#0f172a;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Thanh toán:" style="-fx-text-fill:#64748b; -fx-font-size:13px;" />
                        <Label fx:id="lblTongTienHoan" style="-fx-text-fill:#16a34a; -fx-font-size:18px; -fx-font-weight:bold;" />
                    </HBox>
                    <Separator />
                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Button text="Lưu phiếu đổi trả" onAction="#handleLuu" styleClass="bh-btn-primary" prefHeight="40" prefWidth="180" />
                    </HBox>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>

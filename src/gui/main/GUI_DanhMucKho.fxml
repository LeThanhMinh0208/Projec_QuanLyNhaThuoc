<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.GridPane?> 
<?import javafx.scene.layout.ColumnConstraints?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="25.0" styleClass="dmk-main-bg" stylesheets="@../../resources/css/DanhMucKho.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_DanhMucKhoController">
   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>

   <HBox alignment="CENTER_LEFT" spacing="20">
      <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
         <children>
            <Label styleClass="main-title" text="QUẢN LÝ DANH MỤC KHO" />
            <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
         </children>
      </VBox>
   </HBox>

   <GridPane hgap="15" maxWidth="Infinity">
      <columnConstraints>
         <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
         <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
         <ColumnConstraints percentWidth="33.34" hgrow="ALWAYS" />
      </columnConstraints>
      <children>
         <Button fx:id="btnNhapKho" maxWidth="Infinity" minHeight="50" prefHeight="50" style="-fx-font-size: 16px; -fx-font-weight: bold;" onAction="#moTrangNhapKho" styleClass="top-card, card-green, btn-action" text="Nhập Kho" textFill="WHITE" GridPane.columnIndex="0">
            <graphic>
               <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../../resources/icons/into_warehouse.png" />
                  </image>
               </ImageView>
            </graphic>
         </Button>

         <Button fx:id="btnXuatKho" maxWidth="Infinity" minHeight="50" prefHeight="50" style="-fx-font-size: 16px; -fx-font-weight: bold;" onAction="#handleChuyenTrangXuatKho" styleClass="top-card, card-blue, btn-action" text="Xuất Kho" textFill="WHITE" GridPane.columnIndex="1">
            <graphic>
               <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../../resources/icons/export_icon.png" />
                  </image>
               </ImageView>
            </graphic>
         </Button>

         <Button fx:id="btnKiemKe" maxWidth="Infinity" minHeight="50" prefHeight="50" style="-fx-font-size: 16px; -fx-font-weight: bold;" onAction="#handleChuyenTrangKiemKe" styleClass="top-card, card-orange, btn-action" text="Kiểm Kê Kho" textFill="WHITE" GridPane.columnIndex="2">
            <graphic>
               <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../../resources/icons/inventory_icon.png" />
                  </image>
               </ImageView>
            </graphic>
         </Button>
      </children>
   </GridPane>

   <HBox alignment="CENTER_LEFT" spacing="20.0">
      <ComboBox fx:id="cmbViTriKho" prefHeight="45.0" prefWidth="250.0" promptText="Tất cả vị trí kho" styleClass="dmk-combo" />
      
      <HBox alignment="CENTER_LEFT" styleClass="dmk-search-wrapper" HBox.hgrow="ALWAYS">
         <Label style="-fx-font-size: 16px; -fx-text-fill: #1ea0eb;" text="🔍" />
         <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm kiếm nhanh thuốc theo mã, tên lô, tồn kho..." styleClass="dmk-search-field" HBox.hgrow="ALWAYS" />
         <padding>
            <Insets left="15.0" right="15.0" />
         </padding>
      </HBox>
   </HBox>

   <VBox styleClass="dmk-table-card" VBox.vgrow="ALWAYS">
      <TableView fx:id="tableKho" styleClass="dmk-table" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colMaThuoc" prefWidth="90.0" text="Mã Thuốc" />
          <TableColumn fx:id="colHinhAnh" prefWidth="90.0" text="Ảnh" />
          <TableColumn fx:id="colTenThuoc" prefWidth="250.0" text="Tên Thuốc" />
          <TableColumn fx:id="colViTriKho" prefWidth="150.0" text="Vị Trí Kho" />
          <TableColumn fx:id="colMaLo" prefWidth="120.0" text="Mã Lô" />
          <TableColumn fx:id="colSoLuong" prefWidth="120.0" text="Số Lượng Tồn" style="-fx-alignment: CENTER; -fx-font-weight: bold;" />
          <TableColumn fx:id="colTrangThaiTon" prefWidth="150.0" text="Trạng Thái Tồn" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <padding>
         <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
      </padding>
   </VBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="25.0" styleClass="main-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_DanhMucDonThuocController">
   
   <stylesheets>
    <URL value="@../../resources/css/TrangChu.css" />
    <URL value="@../../resources/css/DanhMucDonThuoc.css" />
</stylesheets>
   
   <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
   <children>
      <Label styleClass="main-title" text="QUẢN LÝ DANH MỤC ĐƠN THUỐC" />
      
      <GridPane hgap="8" maxWidth="Infinity">
         <columnConstraints>
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" />
            <ColumnConstraints percentWidth="33.34" hgrow="ALWAYS" />
         </columnConstraints>
         <children>
            <Button fx:id="btnThem" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleThem" styleClass="top-card, card-green, btn-action" text="＋ Thêm mới" textFill="WHITE" GridPane.columnIndex="0" />
            
            <Button fx:id="btnSua" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleSua" styleClass="top-card, card-blue, btn-action" text="✎ Cập nhật" textFill="WHITE" GridPane.columnIndex="1" />
            
            <Button fx:id="btnXoa" maxWidth="Infinity" minHeight="40" prefHeight="40" style="-fx-font-size: 13px;" onAction="#handleXoa" styleClass="top-card, card-orange, btn-action" text="✖ Xóa" textFill="WHITE" GridPane.columnIndex="2" />
         </children>
      </GridPane>

  <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <ComboBox fx:id="cbLocDanhMuc" prefHeight="45.0" prefWidth="250.0" promptText="Tất cả danh mục" />

            <HBox alignment="CENTER_LEFT" prefHeight="45.0" styleClass="search-box" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="search-icon" text="🔍" />
                  <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm kiếm nhanh thuốc theo mã đơn, bệnh nhân, bác sĩ..." styleClass="search-input" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </HBox>

     <VBox styleClass="panel-white" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="tableThuoc" prefHeight="500.0" styleClass="table-view" style="-fx-fixed-cell-size: 36;" VBox.vgrow="ALWAYS">
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
               <columns>
                 <TableColumn fx:id="colMaDon"     text="Mã Đơn"        prefWidth="100" />
<TableColumn fx:id="colMaHoaDon"  text="Mã Hoá Đơn"    prefWidth="120" />
<TableColumn fx:id="colBacSi"     text="Bác Sĩ"         prefWidth="150" />
<TableColumn fx:id="colChanDoan"  text="Chẩn Đoán"      prefWidth="200" />
<TableColumn fx:id="colBenhNhan"  text="Thông Tin BN"   prefWidth="200" />
<TableColumn fx:id="colHinhAnh"   text="Hình Ảnh Đơn"   prefWidth="120" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>
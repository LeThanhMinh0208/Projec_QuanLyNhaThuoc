<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.Region?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="25.0" styleClass="main-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_DanhMucDonThuocController">
   
   <stylesheets>
    <URL value="@../../resources/css/TrangChu.css" />
    <URL value="@../../resources/css/DanhMucDonThuoc.css" />
   </stylesheets>
   
   <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
   <children>
      <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
          <children>
              <Label styleClass="main-title" text="QUẢN LÝ DANH MỤC ĐƠN THUỐC" />
              <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
          </children>
      </VBox>
      
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <ComboBox fx:id="cbLocDanhMuc" prefHeight="40.0" prefWidth="250.0" promptText="Tất cả bác sĩ" styleClass="xk-input" />

            <HBox alignment="CENTER_LEFT" prefHeight="45.0" styleClass="search-box" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="search-icon" text="🔍" />
                  <TextField fx:id="txtTimKiem" prefHeight="45.0" promptText="Tìm kiếm nhanh thuốc theo mã đơn, bệnh nhân, bác sĩ..." styleClass="search-input" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </HBox>

      <VBox styleClass="panel-white" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="tableThuoc" prefHeight="500.0" styleClass="table-view" style="-fx-fixed-cell-size: 45;" VBox.vgrow="ALWAYS">
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colMaDon"     text="Mã Đơn"        prefWidth="80" />
                  <TableColumn fx:id="colMaHoaDon"  text="Mã Hoá Đơn"    prefWidth="90" />
                  <TableColumn fx:id="colBacSi"     text="Bác Sĩ"         prefWidth="140" />
                  <TableColumn fx:id="colChanDoan"  text="Chẩn Đoán"      prefWidth="160" />
                  <TableColumn fx:id="colBenhNhan"  text="Thông Tin BN"   prefWidth="160" />
                  
                  <TableColumn fx:id="colChiTietHoaDon" text="Chi Tiết HĐ" prefWidth="100" style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colHinhAnh"   text="Hình Ảnh Đơn"   prefWidth="100" style="-fx-alignment: CENTER;" />
                  
                  <TableColumn fx:id="colTaiLap"    text="Tái Lập"        prefWidth="90" style="-fx-alignment: CENTER;" />
                  
                  <TableColumn fx:id="colXoa"       text="Xóa Đơn"        prefWidth="90" style="-fx-alignment: CENTER;" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>
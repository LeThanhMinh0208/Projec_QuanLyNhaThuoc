<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="main-bg" stylesheets="@../../resources/css/QuanLyLoThuoc.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_QuanLyLoThuocController">
   <top>
      <VBox spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
                <children>
                    <Label styleClass="main-title" text="QUẢN LÝ LÔ THUỐC" />
                    <Region prefHeight="4.0" maxWidth="Infinity" styleClass="xk-title-line" />
                </children>
            </VBox>
            
            <HBox spacing="15.0" alignment="CENTER_LEFT">
               <children>
                  <!-- Gọi class đơn -->
                  <Button mnemonicParsing="false" onAction="#toggleFilter" prefHeight="40.0" prefWidth="170.0" styleClass="btn-green-pill" text="✨ Lọc Thông Minh" />
                  <ComboBox fx:id="cbTrangThai" prefHeight="40.0" prefWidth="220.0" promptText="Lọc trạng thái" styleClass="xk-input" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" prefHeight="45.0" spacing="10.0" styleClass="big-search-box">
               <children>
                  <Label style="-fx-font-size: 18px; -fx-text-fill: #0ea5e9;" text="🔍">
                     <HBox.margin><Insets left="15.0" /></HBox.margin>
                  </Label>
                  <TextField fx:id="txtTimKiem" promptText="Tìm theo mã lô, tên thuốc, nhà cung cấp..." styleClass="search-text-field" HBox.hgrow="ALWAYS" />
                  <!-- Gọi class đơn -->
                  <Button mnemonicParsing="false" onAction="#handleLamMoi" prefHeight="35.0" prefWidth="110.0" styleClass="btn-refresh-pill" text="Làm mới">
                     <HBox.margin><Insets right="8.0" /></HBox.margin>
                  </Button>
               </children>
            </HBox>

            <HBox fx:id="paneFilter" alignment="CENTER_LEFT" managed="false" spacing="15.0" styleClass="filter-pane-card" visible="false">
               <children>
                  <Label text="HSD Từ:" styleClass="label-filter" />
                  <DatePicker fx:id="dpHsdTu" prefWidth="120.0" styleClass="xk-input-small" />
                  <Label text="Đến:" styleClass="label-filter" />
                  <DatePicker fx:id="dpHsdDen" prefWidth="120.0" styleClass="xk-input-small" />
                  
                  <Separator orientation="VERTICAL" prefHeight="20.0" />
                  
                  <Label text="Tồn từ:" styleClass="label-filter" />
                  <TextField fx:id="txtTonTu" prefWidth="60.0" styleClass="xk-input-small" />
                  <Label text="Đến:" styleClass="label-filter" />
                  <TextField fx:id="txtTonDen" prefWidth="60.0" styleClass="xk-input-small" />

                  <Separator orientation="VERTICAL" prefHeight="20.0" />
                  
                  <ComboBox fx:id="cbKho" prefWidth="140.0" promptText="Vị trí kho" styleClass="xk-input-small" />
                  <ComboBox fx:id="cbLocNhaCungCap" prefWidth="160.0" promptText="Nhà cung cấp" styleClass="xk-input-small" />
                  
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#clearFilter" styleClass="btn-clear-red" text="Xóa lọc" />
               </children>
               <padding>
                  <Insets bottom="12.0" left="20.0" right="20.0" top="12.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="15.0" left="40.0" right="40.0" top="30.0" />
         </padding>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tableLoThuoc" styleClass="table-view" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colMaLo" prefWidth="100.0" text="MÃ LÔ" />
                <TableColumn fx:id="colAnh" prefWidth="80.0" text="ẢNH" />
                <TableColumn fx:id="colTenThuoc" prefWidth="250.0" text="TÊN THUỐC" />
                <TableColumn fx:id="colHanSuDung" prefWidth="120.0" text="HẠN SỬ DỤNG" />
                <TableColumn fx:id="colSoLuong" prefWidth="100.0" text="SL TỒN" />
                <TableColumn fx:id="colViTri" prefWidth="140.0" text="VỊ TRÍ KHO" />
                <TableColumn fx:id="colTrangThai" prefWidth="130.0" text="TRẠNG THÁI" />
                <TableColumn fx:id="colThaoTac" prefWidth="110.0" text="THAO TÁC" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <VBox fx:id="paneChiTiet" managed="false" styleClass="detail-info-card" visible="false">
               <children>
                  <Label text="📈 THÔNG TIN CHI TIẾT LÔ THUỐC" styleClass="detail-header-text" />
                  <GridPane hgap="15.0" vgap="15.0">
                     <children>
                        <!-- Cột 1 & 2: Ngày Nhập / Giá Nhập -->
                        <Label text="Ngày nhập kho:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="lblNgayNhap" styleClass="value-text" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Giá nhập gốc:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblGiaNhap" styleClass="text-price" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <!-- Cột 3 & 4: Nhà CC / Nhập Ban Đầu -->
                        <Label text="Nhà cung cấp:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <Label fx:id="lblNhaCungCap" styleClass="value-text" text="-" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                        
                        <Label text="SL nhập đầu:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblSlNhapBanDau" styleClass="text-blue" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                        <!-- Cột 5 & 6: Bán / Đổi Trả -->
                        <Label text="Số lượng đã bán:" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblSlDaBan" styleClass="text-green" text="-" GridPane.columnIndex="5" GridPane.rowIndex="0" />

                        <Label text="Khách Đổi/Trả:" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblSlDoiTra" styleClass="text-purple" text="-" GridPane.columnIndex="5" GridPane.rowIndex="1" />
                        
                        <!-- Cột 7 & 8: Trả NCC / Xuất Hủy -->
                        <Label text="Đã trả NCC:" GridPane.columnIndex="6" GridPane.rowIndex="0" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblSlTraNcc" styleClass="text-orange" text="-" GridPane.columnIndex="7" GridPane.rowIndex="0" />

                        <Label text="Đã xuất hủy:" GridPane.columnIndex="6" GridPane.rowIndex="1" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblSlXuatHuy" styleClass="text-red" text="-" GridPane.columnIndex="7" GridPane.rowIndex="1" />

                        <!-- CỘT 9 & 10: KIỂM KÊ -->
                        <Label text="KK Dư:" GridPane.columnIndex="8" GridPane.rowIndex="0" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblKkDu" styleClass="text-blue" text="-" GridPane.columnIndex="9" GridPane.rowIndex="0" />

                        <Label text="KK Thiếu:" GridPane.columnIndex="8" GridPane.rowIndex="1" />
                        <!-- Chỉ gọi 1 class -->
                        <Label fx:id="lblKkThieu" styleClass="text-red" text="-" GridPane.columnIndex="9" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>
               </children>
               <padding>
                  <Insets bottom="20.0" left="25.0" right="25.0" top="15.0" />
               </padding>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets bottom="30.0" left="40.0" right="40.0" />
         </BorderPane.margin>
      </VBox>
   </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.Region?>

<BorderPane stylesheets="@../../resources/css/QuanLyLoThuoc.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.main.GUI_QuanLyLoThuocController">
   <top>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER_LEFT" spacing="5.0" maxWidth="-Infinity">
                <children>
                    <Label styleClass="main-title" text="QUẢN LÝ LÔ THUỐC" />
                    <Region prefHeight="4.0" maxWidth="Infinity" style="-fx-background-color: #0ea5e9; -fx-background-radius: 5px;" />
                </children>
            </VBox>
            
            <HBox spacing="20.0" alignment="CENTER_LEFT">
               <children>
                  <Button mnemonicParsing="false" onAction="#toggleFilter" prefHeight="35.0" prefWidth="150.0" styleClass="btn-smart-filter" text="✨ Lọc Thông Minh" />
                  <ComboBox fx:id="cbTrangThai" prefHeight="35.0" prefWidth="200.0" promptText="Lọc trạng thái" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" prefHeight="45.0" spacing="10.0" styleClass="big-search-box">
               <children>
                  <Label text="🔍" textFill="#1fb1ea">
                     <HBox.margin><Insets left="10.0" /></HBox.margin>
                  </Label>
                  <TextField fx:id="txtTimKiem" promptText="Tìm theo mã lô, tên thuốc..." styleClass="search-text-field" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleLamMoi" prefHeight="35.0" prefWidth="100.0" styleClass="btn-refresh" text="Làm mới">
                     <HBox.margin><Insets right="5.0" /></HBox.margin>
                  </Button>
               </children>
            </HBox>

            <HBox fx:id="paneFilter" alignment="CENTER_LEFT" managed="false" spacing="10.0" styleClass="filter-pane" visible="false">
               <children>
                  <Label text="HSD Từ:" textFill="#34495e" />
                  <DatePicker fx:id="dpHsdTu" prefWidth="110.0" />
                  <Label text="Đến:" textFill="#34495e" />
                  <DatePicker fx:id="dpHsdDen" prefWidth="110.0" />
                  
                  <Label text=" | Tồn từ:" textFill="#34495e" />
                  <TextField fx:id="txtTonTu" prefWidth="50.0" />
                  <Label text="đến:" textFill="#34495e" />
                  <TextField fx:id="txtTonDen" prefWidth="50.0" />

                  <Label text=" | Kho:" textFill="#34495e" />
                  <ComboBox fx:id="cbKho" prefWidth="120.0" />
                  
                  <Label text=" | NCC:" textFill="#34495e" />
                  <ComboBox fx:id="cbLocNhaCungCap" prefWidth="150.0" />
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <Button mnemonicParsing="false" onAction="#clearFilter" styleClass="btn-clear-filter" text="Xóa lọc" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="40.0" right="40.0" top="30.0" />
         </padding>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="10.0" styleClass="table-container" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tableLoThuoc" prefHeight="300.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colMaLo" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Mã Lô" />
                <TableColumn fx:id="colAnh" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Ảnh" />
                <TableColumn fx:id="colTenThuoc" prefWidth="220.0" text="Tên Thuốc" />
                <TableColumn fx:id="colHanSuDung" prefWidth="110.0" style="-fx-alignment: CENTER;" text="Hạn Sử Dụng" />
                <TableColumn fx:id="colSoLuong" prefWidth="80.0" style="-fx-alignment: CENTER;" text="SL Tồn" />
                <TableColumn fx:id="colViTri" prefWidth="130.0" style="-fx-alignment: CENTER;" text="Vị Trí Kho" />
                <TableColumn fx:id="colTrangThai" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Trạng Thái" />
                <TableColumn fx:id="colThaoTac" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Thao Tác" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <VBox fx:id="paneChiTiet" managed="false" styleClass="detail-pane" visible="false">
               <children>
                  <Label text="Thông Tin Lô Thuốc" textFill="#1fb1ea">
                     <font><Font name="System Bold" size="16.0" /></font>
                     <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                  </Label>
                 <GridPane hgap="25.0" vgap="15.0">
                     <children>
                        <Label text="Ngày nhập kho:" textFill="#7f8c8d" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="lblNgayNhap" styleClass="text-bold" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Giá nhập:" textFill="#7f8c8d" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="lblGiaNhap" styleClass="text-bold" text="-" textFill="#e74c3c" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Nhà cung cấp:" textFill="#7f8c8d" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <Label fx:id="lblNhaCungCap" styleClass="text-bold" text="-" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                        
                        <Label text="SL nhập ban đầu:" textFill="#7f8c8d" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <Label fx:id="lblSlNhapBanDau" styleClass="text-bold" text="-" textFill="#2980b9" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                        <Label text="Số lượng đã bán:" textFill="#7f8c8d" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                        <Label fx:id="lblSlDaBan" styleClass="text-bold" text="-" textFill="#27ae60" GridPane.columnIndex="5" GridPane.rowIndex="0" />

                        <Label text="Khách Đổi/Trả:" textFill="#7f8c8d" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                        <Label fx:id="lblSlDoiTra" styleClass="text-bold" text="-" textFill="#8e44ad" GridPane.columnIndex="5" GridPane.rowIndex="1" />
                        
                        <Label text="SL Trả NCC:" textFill="#7f8c8d" GridPane.columnIndex="6" GridPane.rowIndex="0" />
                        <Label fx:id="lblSlTraNcc" styleClass="text-bold" text="-" textFill="#d35400" GridPane.columnIndex="7" GridPane.rowIndex="0" />

                        <Label text="SL Xuất hủy:" textFill="#7f8c8d" GridPane.columnIndex="6" GridPane.rowIndex="1" />
                        <Label fx:id="lblSlXuatHuy" styleClass="text-bold" text="-" textFill="#c0392b" GridPane.columnIndex="7" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>
               </children>
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets bottom="30.0" left="40.0" right="40.0" />
         </BorderPane.margin>
      </VBox>
   </center>
</BorderPane>